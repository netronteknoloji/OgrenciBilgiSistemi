<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:OgrenciBilgiSistemi.Mobil.Views"
             x:Class="OgrenciBilgiSistemi.Mobil.Views.AdminSinifOgrenciListeView"
             x:Name="SayfaKoku"
             Title="Sınıf Yoklama"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource UygulamaArkaPlan}">

    <Grid RowDefinitions="125, Auto, Auto, *">

        <Border Grid.Row="0" StrokeThickness="0" Background="{StaticResource AdminBaslikGradyan}" VerticalOptions="FillAndExpand">
            <Border.Shadow>
                <Shadow Brush="{StaticResource AdminRenk}" Offset="0,4" Radius="15" Opacity="0.35" />
            </Border.Shadow>
            <Grid>
                <views:AnaBaslikView ShowBack="True" ShowProfile="False" VurguRenk="{StaticResource AdminRenk}" />
                <VerticalStackLayout Spacing="2" VerticalOptions="End" HorizontalOptions="Center" Margin="20,0,20,15">
                    <Label Text="{Binding SinifAdi}" FontSize="18" FontFamily="OpenSansSemibold" TextColor="White" HorizontalTextAlignment="Center" />
                    <Label Text="{Binding AltBaslik}" FontSize="14" TextColor="White" Opacity="0.8" HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </Grid>
        </Border>

        <!-- Tarih seçici -->
        <Border Grid.Row="1" Margin="15,-15,15,8" StrokeShape="RoundRectangle 14" StrokeThickness="0"
                BackgroundColor="{StaticResource Kart}" Padding="14,10">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,8" Radius="24" Opacity="0.10" />
            </Border.Shadow>
            <Grid ColumnDefinitions="Auto, *">
                <Label Grid.Column="0" Text="📅 Tarih:" FontSize="14" FontFamily="OpenSansSemibold"
                       TextColor="{StaticResource MetinKoyu}" VerticalOptions="Center" Margin="0,0,10,0" />
                <DatePicker Grid.Column="1"
                            Date="{Binding SecilenTarih}"
                            Format="d MMMM yyyy"
                            FontSize="14"
                            TextColor="{StaticResource MetinKoyu}" />
            </Grid>
        </Border>

        <!-- Ders saati başlık satırı -->
        <Grid Grid.Row="2" Margin="15,4,15,8" ColumnDefinitions="*, 240">
            <Label Grid.Column="0" Text="Öğrenci" FontSize="11" FontFamily="OpenSansSemibold"
                   TextColor="{StaticResource MetinSoluk}" VerticalOptions="Center" />
            <Grid Grid.Column="1" ColumnDefinitions="*,*,*,*,*,*,*,*" ColumnSpacing="2">
                <Label Grid.Column="0" Text="1" FontSize="10" TextColor="{StaticResource MetinSoluk}" HorizontalTextAlignment="Center" FontFamily="OpenSansSemibold" />
                <Label Grid.Column="1" Text="2" FontSize="10" TextColor="{StaticResource MetinSoluk}" HorizontalTextAlignment="Center" FontFamily="OpenSansSemibold" />
                <Label Grid.Column="2" Text="3" FontSize="10" TextColor="{StaticResource MetinSoluk}" HorizontalTextAlignment="Center" FontFamily="OpenSansSemibold" />
                <Label Grid.Column="3" Text="4" FontSize="10" TextColor="{StaticResource MetinSoluk}" HorizontalTextAlignment="Center" FontFamily="OpenSansSemibold" />
                <Label Grid.Column="4" Text="5" FontSize="10" TextColor="{StaticResource MetinSoluk}" HorizontalTextAlignment="Center" FontFamily="OpenSansSemibold" />
                <Label Grid.Column="5" Text="6" FontSize="10" TextColor="{StaticResource MetinSoluk}" HorizontalTextAlignment="Center" FontFamily="OpenSansSemibold" />
                <Label Grid.Column="6" Text="7" FontSize="10" TextColor="{StaticResource MetinSoluk}" HorizontalTextAlignment="Center" FontFamily="OpenSansSemibold" />
                <Label Grid.Column="7" Text="8" FontSize="10" TextColor="{StaticResource MetinSoluk}" HorizontalTextAlignment="Center" FontFamily="OpenSansSemibold" />
            </Grid>
        </Grid>

        <CollectionView Grid.Row="3"
                        ItemsSource="{Binding Ogrenciler}"
                        Margin="15,0,15,10"
                        SelectionMode="None">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="6" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border StrokeShape="RoundRectangle 12" StrokeThickness="0" Padding="12,10"
                            BackgroundColor="{StaticResource Kart}">
                        <Border.Shadow>
                            <Shadow Brush="Black" Offset="0,2" Radius="8" Opacity="0.06" />
                        </Border.Shadow>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding BindingContext.OgrenciSecCommand, Source={x:Reference SayfaKoku}}"
                                CommandParameter="{Binding .}" />
                        </Border.GestureRecognizers>
                        <Grid ColumnDefinitions="*, 240" RowDefinitions="Auto, Auto" RowSpacing="3">
                            <VerticalStackLayout Grid.Column="0" Grid.Row="0" Grid.RowSpan="2" Spacing="2" VerticalOptions="Center">
                                <Label Text="{Binding OgrenciAdSoyad}" FontSize="13"
                                       FontFamily="OpenSansSemibold" TextColor="{StaticResource MetinKoyu}"
                                       LineBreakMode="TailTruncation" />
                                <Label Text="{Binding OgretmenSatiri}" FontSize="10" TextColor="{StaticResource MetinSoluk}" />
                            </VerticalStackLayout>

                            <Grid Grid.Column="1" Grid.Row="0" Grid.RowSpan="2"
                                  ColumnDefinitions="*,*,*,*,*,*,*,*" ColumnSpacing="2"
                                  VerticalOptions="Center">
                                <Border Grid.Column="0" StrokeShape="RoundRectangle 5" StrokeThickness="0"
                                        BackgroundColor="{Binding Ders1Renk}" HeightRequest="22" />
                                <Border Grid.Column="1" StrokeShape="RoundRectangle 5" StrokeThickness="0"
                                        BackgroundColor="{Binding Ders2Renk}" HeightRequest="22" />
                                <Border Grid.Column="2" StrokeShape="RoundRectangle 5" StrokeThickness="0"
                                        BackgroundColor="{Binding Ders3Renk}" HeightRequest="22" />
                                <Border Grid.Column="3" StrokeShape="RoundRectangle 5" StrokeThickness="0"
                                        BackgroundColor="{Binding Ders4Renk}" HeightRequest="22" />
                                <Border Grid.Column="4" StrokeShape="RoundRectangle 5" StrokeThickness="0"
                                        BackgroundColor="{Binding Ders5Renk}" HeightRequest="22" />
                                <Border Grid.Column="5" StrokeShape="RoundRectangle 5" StrokeThickness="0"
                                        BackgroundColor="{Binding Ders6Renk}" HeightRequest="22" />
                                <Border Grid.Column="6" StrokeShape="RoundRectangle 5" StrokeThickness="0"
                                        BackgroundColor="{Binding Ders7Renk}" HeightRequest="22" />
                                <Border Grid.Column="7" StrokeShape="RoundRectangle 5" StrokeThickness="0"
                                        BackgroundColor="{Binding Ders8Renk}" HeightRequest="22" />
                            </Grid>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="10" Padding="20">
                    <Label Text="{Binding BosDurum}" FontSize="16" TextColor="{StaticResource MetinSoluk}" HorizontalOptions="Center" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>
            <CollectionView.Footer>
                <!-- Renk açıklaması — Shared/Constants/YoklamaRenkleri.cs paletiyle eşleşir
                     (çipler SinifYoklamaOzet üzerinden o paletle boyanır) -->
                <Grid ColumnDefinitions="*,*,*,*" RowDefinitions="Auto,Auto" RowSpacing="6" ColumnSpacing="6" Margin="0,12,0,0">
                    <HorizontalStackLayout Grid.Row="0" Grid.Column="0" Spacing="4">
                        <Border WidthRequest="14" HeightRequest="14" StrokeShape="RoundRectangle 3" StrokeThickness="0" BackgroundColor="#198754" />
                        <Label Text="Geldi" FontSize="10" TextColor="{StaticResource MetinSoluk}" VerticalOptions="Center" />
                    </HorizontalStackLayout>
                    <HorizontalStackLayout Grid.Row="0" Grid.Column="1" Spacing="4">
                        <Border WidthRequest="14" HeightRequest="14" StrokeShape="RoundRectangle 3" StrokeThickness="0" BackgroundColor="#DC3545" />
                        <Label Text="Gelmedi" FontSize="10" TextColor="{StaticResource MetinSoluk}" VerticalOptions="Center" />
                    </HorizontalStackLayout>
                    <HorizontalStackLayout Grid.Row="0" Grid.Column="2" Spacing="4">
                        <Border WidthRequest="14" HeightRequest="14" StrokeShape="RoundRectangle 3" StrokeThickness="0" BackgroundColor="#FFC107" />
                        <Label Text="Geç" FontSize="10" TextColor="{StaticResource MetinSoluk}" VerticalOptions="Center" />
                    </HorizontalStackLayout>
                    <HorizontalStackLayout Grid.Row="0" Grid.Column="3" Spacing="4">
                        <Border WidthRequest="14" HeightRequest="14" StrokeShape="RoundRectangle 3" StrokeThickness="0" BackgroundColor="#0D6EFD" />
                        <Label Text="İzinli" FontSize="10" TextColor="{StaticResource MetinSoluk}" VerticalOptions="Center" />
                    </HorizontalStackLayout>
                    <HorizontalStackLayout Grid.Row="1" Grid.Column="0" Spacing="4">
                        <Border WidthRequest="14" HeightRequest="14" StrokeShape="RoundRectangle 3" StrokeThickness="0" BackgroundColor="#6F42C1" />
                        <Label Text="Raporlu" FontSize="10" TextColor="{StaticResource MetinSoluk}" VerticalOptions="Center" />
                    </HorizontalStackLayout>
                    <HorizontalStackLayout Grid.Row="1" Grid.Column="1" Spacing="4">
                        <Border WidthRequest="14" HeightRequest="14" StrokeShape="RoundRectangle 3" StrokeThickness="0" BackgroundColor="#212529" />
                        <Label Text="Nöbetçi" FontSize="10" TextColor="{StaticResource MetinSoluk}" VerticalOptions="Center" />
                    </HorizontalStackLayout>
                    <HorizontalStackLayout Grid.Row="1" Grid.Column="2" Spacing="4">
                        <Border WidthRequest="14" HeightRequest="14" StrokeShape="RoundRectangle 3" StrokeThickness="0" BackgroundColor="#6C757D" />
                        <Label Text="Görevli" FontSize="10" TextColor="{StaticResource MetinSoluk}" VerticalOptions="Center" />
                    </HorizontalStackLayout>
                    <HorizontalStackLayout Grid.Row="1" Grid.Column="3" Spacing="4">
                        <Border WidthRequest="14" HeightRequest="14" StrokeShape="RoundRectangle 3" StrokeThickness="0" BackgroundColor="#F8F9FA" />
                        <Label Text="Yok" FontSize="10" TextColor="{StaticResource MetinSoluk}" VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </Grid>
            </CollectionView.Footer>
        </CollectionView>
    </Grid>
</ContentPage>
