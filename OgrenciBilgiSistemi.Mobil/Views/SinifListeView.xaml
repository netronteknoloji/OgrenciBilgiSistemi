<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:OgrenciBilgiSistemi.Mobil.Views"
             x:Class="OgrenciBilgiSistemi.Mobil.Views.SinifListeView"
             x:Name="SayfaKoku"
             Title="Sınıf Listesi"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource UygulamaArkaPlan}">

    <Grid RowDefinitions="125, Auto, *">

        <Border Grid.Row="0"
                StrokeThickness="0"
                Background="{StaticResource OgretmenBaslikGradyan}"
                VerticalOptions="FillAndExpand">
            <Border.Shadow>
                <Shadow Brush="{StaticResource OgretmenRenk}" Offset="0,4" Radius="15" Opacity="0.35" />
            </Border.Shadow>

            <Grid>
                <views:AnaBaslikView x:Name="MyHeader"
                                      ShowBack="False"
                                      ShowProfile="True"
                                      VurguRenk="{StaticResource OgretmenRenk}" />

                <VerticalStackLayout Spacing="2"
                                     VerticalOptions="End"
                                     Margin="20,0,20,35">
                    <Label Text="Öğretmen Paneli"
                           FontSize="18"
                           FontFamily="OpenSansSemibold"
                           TextColor="White" />
                    <Label Text="Sınıf Seçiniz"
                           FontSize="14"
                           FontFamily="OpenSansSemibold"
                           TextColor="White"
                           Opacity="0.8" />
                </VerticalStackLayout>
            </Grid>
        </Border>

        <VerticalStackLayout Grid.Row="1" Spacing="8">
            <Border Style="{StaticResource YuzenKart}"
                    Margin="15,-28,15,0"
                    HeightRequest="55"
                    StrokeShape="RoundRectangle 28">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,8" Radius="24" Opacity="0.10" />
                </Border.Shadow>
                <Grid ColumnDefinitions="55, *">
                    <Label Grid.Column="0" Text="🔍" VerticalOptions="Center" HorizontalOptions="Center" FontSize="18" TextColor="{StaticResource MetinSoluk}" />
                    <Entry Grid.Column="1" Placeholder="Hangi sınıfı arıyorsun?" PlaceholderColor="{StaticResource MetinSoluk}"
                           TextColor="{StaticResource MetinKoyu}" FontSize="15" VerticalOptions="Center" Text="{Binding AramaMetni}" />
                </Grid>
            </Border>

            <!-- Randevu, Müsaitlik ve Bildirim butonları -->
            <Grid ColumnDefinitions="*, *, *" Margin="15,0,15,5" ColumnSpacing="8">
                <Border Grid.Column="0" StrokeShape="RoundRectangle 12" StrokeThickness="0"
                        BackgroundColor="{StaticResource OgretmenRenk}" Padding="8,6" HeightRequest="36">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding RandevularCommand}" />
                    </Border.GestureRecognizers>
                    <Label Text="Randevular" FontSize="12" TextColor="White" FontFamily="OpenSansSemibold"
                           HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>
                <Border Grid.Column="1" StrokeShape="RoundRectangle 12" StrokeThickness="0"
                        BackgroundColor="{StaticResource OgretmenKoyu}" Padding="8,6" HeightRequest="36">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding OgretmenRandevuCommand}" />
                    </Border.GestureRecognizers>
                    <Label Text="Randevu Takvimi" FontSize="12" TextColor="White" FontFamily="OpenSansSemibold"
                           HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>
                <Grid Grid.Column="2">
                    <Border StrokeShape="RoundRectangle 12" StrokeThickness="0"
                            BackgroundColor="{StaticResource OgretmenRenk}" Padding="8,6" HeightRequest="36">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding BildirimlerCommand}" />
                        </Border.GestureRecognizers>
                        <Label Text="Bildirimler" FontSize="12" TextColor="White" FontFamily="OpenSansSemibold"
                               HorizontalOptions="Center" VerticalOptions="Center" />
                    </Border>
                    <Border StrokeShape="RoundRectangle 8" StrokeThickness="0"
                            BackgroundColor="{StaticResource Tehlike}" WidthRequest="16" HeightRequest="16"
                            HorizontalOptions="End" VerticalOptions="Start" Margin="0,-6,-6,0"
                            IsVisible="{Binding BildirimBadgeGorunur}">
                        <Label Text="{Binding BildirimSayiMetni}" FontSize="8" TextColor="White"
                               HorizontalOptions="Center" VerticalOptions="Center" />
                    </Border>
                </Grid>
            </Grid>

            <!-- Duyuru Yap butonu -->
            <Border Margin="15,5,15,5" StrokeShape="RoundRectangle 12" StrokeThickness="0"
                    BackgroundColor="{StaticResource OgretmenRenk}" Padding="8,6" HeightRequest="36">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding DuyuruYapCommand}" />
                </Border.GestureRecognizers>
                <Label Text="Duyuru Yap" FontSize="12" TextColor="White" FontFamily="OpenSansSemibold"
                       HorizontalOptions="Center" VerticalOptions="Center" />
            </Border>
        </VerticalStackLayout>

        <CollectionView Grid.Row="2" Margin="15,0" SelectionMode="None" ItemsSource="{Binding FiltreliSiniflar}">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="10" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border StrokeShape="RoundRectangle 16" StrokeThickness="0" BackgroundColor="{StaticResource Kart}" Padding="0">
                        <Border.Shadow>
                            <Shadow Brush="Black" Offset="0,2" Radius="8" Opacity="0.06" />
                        </Border.Shadow>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer
                            Command="{Binding BindingContext.SinifSecCommand, Source={x:Reference SayfaKoku}}"
                            CommandParameter="{Binding .}" />
                        </Border.GestureRecognizers>
                        <Grid ColumnDefinitions="8, *, Auto">
                            <BoxView Grid.Column="0" BackgroundColor="{StaticResource OgretmenRenk}" WidthRequest="8" HorizontalOptions="Start"/>
                            <HorizontalStackLayout Grid.Column="1" Spacing="15" Padding="15,12">
                                <Image Source="classroom.png" WidthRequest="30" HeightRequest="30" VerticalOptions="Center" />
                                <VerticalStackLayout VerticalOptions="Center">
                                    <Label Text="{Binding Ad}" FontSize="16" FontFamily="OpenSansSemibold" TextColor="{StaticResource MetinKoyu}" />
                                    <Label Text="{Binding OgrenciSayisi, StringFormat='Sınıf Mevcudu: {0}'}" FontSize="11" TextColor="{StaticResource OgretmenRenk}" />
                                </VerticalStackLayout>
                            </HorizontalStackLayout>
                            <Label Grid.Column="2" Text="→" FontSize="24" TextColor="{StaticResource OgretmenRenk}" VerticalOptions="Center" Margin="0,0,15,0" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
