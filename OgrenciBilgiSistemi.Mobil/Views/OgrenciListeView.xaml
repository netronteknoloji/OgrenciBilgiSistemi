<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:OgrenciBilgiSistemi.Mobil.Views"
             x:Class="OgrenciBilgiSistemi.Mobil.Views.OgrenciListeView"
             x:Name="SayfaKoku"
             Title="Yoklama Ekranı"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource UygulamaArkaPlan}">

    <ContentPage.Resources>
        <Style x:Key="StatusBorderStyle" TargetType="Border">
            <Setter Property="StrokeShape" Value="RoundRectangle 12" />
            <Setter Property="StrokeThickness" Value="1" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Margin" Value="0,0,6,6" />
            <Setter Property="BackgroundColor" Value="{StaticResource Kart}" />
            <Setter Property="Stroke" Value="{StaticResource CizgiBrush}" />
        </Style>
    </ContentPage.Resources>

    <Grid RowDefinitions="125, Auto, Auto, Auto, *, Auto">

        <Border Grid.Row="0"
                StrokeThickness="0"
                Background="{StaticResource OgretmenBaslikGradyan}">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,4" Radius="15" Opacity="0.18" />
            </Border.Shadow>

            <Grid>
                <views:AnaBaslikView x:Name="MyHeader"
                                      ShowBack="True"
                                      ShowProfile="True"
                                      VurguRenk="{StaticResource OgretmenRenk}" />

                <Label Text="{Binding BirimAd}"
                       FontSize="18"
                       FontFamily="OpenSansSemibold"
                       HorizontalOptions="Center"
                       VerticalOptions="End"
                       Margin="0,0,0,35"
                       TextColor="White" />
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Style="{StaticResource YuzenKart}"
                Margin="15,-28,15,10"
                HeightRequest="55"
                StrokeShape="RoundRectangle 28">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,8" Radius="24" Opacity="0.10" />
            </Border.Shadow>
            <Grid ColumnDefinitions="55, *">
                <Label Grid.Column="0" Text="⏰" VerticalOptions="Center" HorizontalOptions="Center" FontSize="18" />
                <Picker Grid.Column="1" Title="Ders Saati Seçiniz" TitleColor="{StaticResource MetinSoluk}"
                        TextColor="{StaticResource MetinKoyu}" VerticalOptions="Center" SelectedIndex="{Binding SecilenPeriyotIndex}">
                    <Picker.ItemsSource>
                        <x:Array Type="{x:Type x:String}">
                            <x:String>1. Ders</x:String>
                            <x:String>2. Ders</x:String>
                            <x:String>3. Ders</x:String>
                            <x:String>4. Ders</x:String>
                            <x:String>5. Ders</x:String>
                            <x:String>6. Ders</x:String>
                            <x:String>7. Ders</x:String>
                            <x:String>8. Ders</x:String>
                        </x:Array>
                    </Picker.ItemsSource>
                </Picker>
            </Grid>
        </Border>

        <Border Grid.Row="2" Margin="15,0,15,5" HeightRequest="45"
                StrokeShape="RoundRectangle 22" StrokeThickness="0" BackgroundColor="{StaticResource Kart}">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,2" Radius="6" Opacity="0.06" />
            </Border.Shadow>
            <Grid ColumnDefinitions="45, *">
                <Label Grid.Column="0" Text="&#x1F50D;" VerticalOptions="Center" HorizontalOptions="Center" FontSize="16" />
                <Entry Grid.Column="1" Placeholder="Ad Soyad veya No ile ara..."
                       PlaceholderColor="{StaticResource MetinSoluk}" TextColor="{StaticResource MetinKoyu}" FontSize="14"
                       VerticalOptions="Center" BackgroundColor="Transparent"
                       Text="{Binding AramaMetni}" />
            </Grid>
        </Border>

        <Border Grid.Row="3" IsVisible="{Binding StatusUyariGorunur}" Margin="15,5,15,10"
                StrokeShape="RoundRectangle 10" StrokeThickness="0" BackgroundColor="{StaticResource UyariSoft}">
            <Label Text="&#x26A0;&#xFE0F; Bu dersin yoklaması daha önce kaydedilmiştir." Padding="12"
                   TextColor="{StaticResource UyariKoyu}" HorizontalOptions="Center" FontSize="13" />
        </Border>

        <CollectionView Grid.Row="4" Margin="15,5" ItemsSource="{Binding FiltreliOgrenciler}">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="10" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border StrokeShape="RoundRectangle 16" StrokeThickness="0" BackgroundColor="{StaticResource Kart}" Padding="15">
                        <Border.Shadow>
                            <Shadow Brush="Black" Offset="0,2" Radius="8" Opacity="0.06" />
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="12">
                            <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="12" VerticalOptions="Center">
                                <Border Grid.Column="0" StrokeShape="RoundRectangle 20" HeightRequest="40"
                                        WidthRequest="40" StrokeThickness="0" BackgroundColor="{StaticResource KartSoluk}">
                                    <Image Aspect="AspectFill" Source="{Binding OgrenciData.OgrenciGorsel, TargetNullValue='user_icon.png', FallbackValue='user_icon.png'}" />
                                </Border>
                                <Label Grid.Column="1" Text="{Binding OgrenciData.OgrenciGorunenAd}" FontSize="16"
                                       FontFamily="OpenSansSemibold" TextColor="{StaticResource MetinKoyu}" VerticalOptions="Center" LineBreakMode="TailTruncation" />
                                <Border Grid.Column="2" Padding="0" HeightRequest="30" WidthRequest="30"
                                        StrokeShape="RoundRectangle 15" StrokeThickness="0"
                                        BackgroundColor="{StaticResource OgretmenRenk}" HorizontalOptions="End" VerticalOptions="Center">
                                    <Border.Shadow>
                                        <Shadow Brush="Black" Offset="0,2" Radius="5" Opacity="0.15" />
                                    </Border.Shadow>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding BindingContext.OgrenciDetayCommand, Source={x:Reference SayfaKoku}}"
                                            CommandParameter="{Binding .}" />
                                    </Border.GestureRecognizers>
                                    <Label Text="i" TextColor="White" FontSize="15" FontAttributes="Bold"
                                           HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                                </Border>
                            </Grid>

                            <FlexLayout Wrap="Wrap" Direction="Row" JustifyContent="Start">
                                <Border Style="{StaticResource StatusBorderStyle}">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnStatusTapped" CommandParameter="1" />
                                    </Border.GestureRecognizers>
                                    <Label Text="Geldi" FontSize="12" TextColor="{StaticResource MetinGovde}">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding SecilenDurumId}" Value="1">
                                                <Setter Property="TextColor" Value="White" />
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>
                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border" Binding="{Binding SecilenDurumId}" Value="1">
                                            <Setter Property="BackgroundColor" Value="{StaticResource Basari}" />
                                            <Setter Property="Stroke" Value="{StaticResource Basari}" />
                                        </DataTrigger>
                                    </Border.Triggers>
                                </Border>

                                <Border Style="{StaticResource StatusBorderStyle}">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnStatusTapped" CommandParameter="2" />
                                    </Border.GestureRecognizers>
                                    <Label Text="Gelmedi" FontSize="12" TextColor="{StaticResource MetinGovde}">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding SecilenDurumId}" Value="2">
                                                <Setter Property="TextColor" Value="White" />
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>
                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border" Binding="{Binding SecilenDurumId}" Value="2">
                                            <Setter Property="BackgroundColor" Value="{StaticResource Tehlike}" />
                                            <Setter Property="Stroke" Value="{StaticResource Tehlike}" />
                                        </DataTrigger>
                                    </Border.Triggers>
                                </Border>

                                <Border Style="{StaticResource StatusBorderStyle}">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnStatusTapped" CommandParameter="3" />
                                    </Border.GestureRecognizers>
                                    <Label Text="Geç Geldi" FontSize="12" TextColor="{StaticResource MetinGovde}">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding SecilenDurumId}" Value="3">
                                                <Setter Property="TextColor" Value="White" />
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>
                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border" Binding="{Binding SecilenDurumId}" Value="3">
                                            <Setter Property="BackgroundColor" Value="{StaticResource Uyari}" />
                                            <Setter Property="Stroke" Value="{StaticResource Uyari}" />
                                        </DataTrigger>
                                    </Border.Triggers>
                                </Border>

                                <Border Style="{StaticResource StatusBorderStyle}">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnStatusTapped" CommandParameter="4" />
                                    </Border.GestureRecognizers>
                                    <Label Text="İzinli" FontSize="12" TextColor="{StaticResource MetinGovde}">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding SecilenDurumId}" Value="4">
                                                <Setter Property="TextColor" Value="White" />
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>
                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border" Binding="{Binding SecilenDurumId}" Value="4">
                                            <Setter Property="BackgroundColor" Value="{StaticResource DurumIzinli}" />
                                            <Setter Property="Stroke" Value="{StaticResource DurumIzinli}" />
                                        </DataTrigger>
                                    </Border.Triggers>
                                </Border>

                                <Border Style="{StaticResource StatusBorderStyle}">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnStatusTapped" CommandParameter="5" />
                                    </Border.GestureRecognizers>
                                    <Label Text="Raporlu" FontSize="12" TextColor="{StaticResource MetinGovde}">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding SecilenDurumId}" Value="5">
                                                <Setter Property="TextColor" Value="White" />
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>
                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border" Binding="{Binding SecilenDurumId}" Value="5">
                                            <Setter Property="BackgroundColor" Value="{StaticResource DurumRaporlu}" />
                                            <Setter Property="Stroke" Value="{StaticResource DurumRaporlu}" />
                                        </DataTrigger>
                                    </Border.Triggers>
                                </Border>

                                <Border Style="{StaticResource StatusBorderStyle}">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnStatusTapped" CommandParameter="6" />
                                    </Border.GestureRecognizers>
                                    <Label Text="Nöbetçi" FontSize="12" TextColor="{StaticResource MetinGovde}">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding SecilenDurumId}" Value="6">
                                                <Setter Property="TextColor" Value="White" />
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>
                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border" Binding="{Binding SecilenDurumId}" Value="6">
                                            <Setter Property="BackgroundColor" Value="{StaticResource MetinKoyu}" />
                                            <Setter Property="Stroke" Value="{StaticResource MetinKoyu}" />
                                        </DataTrigger>
                                    </Border.Triggers>
                                </Border>

                                <Border Style="{StaticResource StatusBorderStyle}">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnStatusTapped" CommandParameter="7" />
                                    </Border.GestureRecognizers>
                                    <Label Text="Görevli" FontSize="12" TextColor="{StaticResource MetinGovde}">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding SecilenDurumId}" Value="7">
                                                <Setter Property="TextColor" Value="White" />
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>
                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border" Binding="{Binding SecilenDurumId}" Value="7">
                                            <Setter Property="BackgroundColor" Value="{StaticResource MetinSoluk}" />
                                            <Setter Property="Stroke" Value="{StaticResource MetinSoluk}" />
                                        </DataTrigger>
                                    </Border.Triggers>
                                </Border>
                            </FlexLayout>
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Border Grid.Row="5" Padding="15,10,15,20" BackgroundColor="{StaticResource Kart}" StrokeThickness="0">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,-5" Radius="10" Opacity="0.05" />
            </Border.Shadow>
            <Grid>
                <Button Text="YOKLAMAYI KAYDET" HeightRequest="54" CornerRadius="14"
                        FontFamily="OpenSansSemibold"
                        BackgroundColor="{StaticResource OgretmenRenk}" TextColor="White"
                        Command="{Binding KaydetCommand}" IsVisible="{Binding KaydetGorunur}" />
                <Button Text="YOKLAMAYI GÜNCELLE" HeightRequest="54" CornerRadius="14"
                        FontFamily="OpenSansSemibold"
                        BackgroundColor="{StaticResource OgretmenKoyu}" TextColor="White"
                        Command="{Binding GuncelleCommand}" IsVisible="{Binding GuncelleGorunur}" />
            </Grid>
        </Border>
    </Grid>
</ContentPage>
