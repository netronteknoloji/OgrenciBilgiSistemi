<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:OgrenciBilgiSistemi.Mobil.Views"
             x:Class="OgrenciBilgiSistemi.Mobil.Views.AdminAnaSayfaView"
             Title="Yönetici"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource UygulamaArkaPlan}">

    <ScrollView>
        <Grid RowDefinitions="125, Auto, Auto">

            <Border Grid.Row="0"
                    StrokeThickness="0"
                    Background="{StaticResource AdminBaslikGradyan}"
                    VerticalOptions="FillAndExpand">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,4" Radius="15" Opacity="0.18" />
                </Border.Shadow>

                <Grid>
                    <views:AnaBaslikView x:Name="MyHeader"
                                          ShowBack="False"
                                          ShowProfile="True"
                                          VurguRenk="{StaticResource AdminRenk}" />

                    <VerticalStackLayout Spacing="2"
                                         VerticalOptions="End"
                                         Margin="20,0,20,35">
                        <Label Text="{Binding KarsilamaMetni}"
                               FontSize="18"
                               FontFamily="OpenSansSemibold"
                               TextColor="White" />
                        <Label Text="Yönetici Paneli"
                               FontSize="14"
                               FontFamily="OpenSansSemibold"
                               TextColor="White"
                               Opacity="0.8" />
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <!-- Okul adı bilgisi -->
            <Border Grid.Row="1"
                    Style="{StaticResource YuzenKart}"
                    Margin="15,-28,15,10"
                    HeightRequest="55"
                    StrokeShape="RoundRectangle 28">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,8" Radius="24" Opacity="0.10" />
                </Border.Shadow>
                <Grid ColumnDefinitions="55, *">
                    <Label Grid.Column="0" Text="&#x1F3EB;"
                           VerticalOptions="Center" HorizontalOptions="Center" FontSize="22" />
                    <Label Grid.Column="1"
                           Text="{Binding OkulAdi}"
                           VerticalOptions="Center"
                           FontSize="15"
                           FontFamily="OpenSansSemibold"
                           TextColor="{StaticResource MetinKoyu}" />
                </Grid>
            </Border>

            <!-- KPI kartları -->
            <Grid Grid.Row="2"
                  Margin="15,5,15,20"
                  ColumnDefinitions="*,*"
                  RowDefinitions="Auto,Auto,Auto,Auto"
                  ColumnSpacing="10"
                  RowSpacing="10">

                <!-- Toplam öğrenci -->
                <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource KpiKart}">
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,2" Radius="8" Opacity="0.06" />
                    </Border.Shadow>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding OgrencilereGitCommand}" />
                    </Border.GestureRecognizers>
                    <Grid Padding="14" RowDefinitions="Auto,*,Auto">
                        <Border Grid.Row="0" BackgroundColor="{StaticResource AdminSoft}" StrokeThickness="0"
                                StrokeShape="RoundRectangle 12" WidthRequest="44" HeightRequest="44" HorizontalOptions="Start">
                            <Label Text="&#x1F468;&#x200D;&#x1F393;" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>
                        <Label Grid.Row="1" Style="{StaticResource KpiSayi}"
                               Text="{Binding OgrenciSayisi}" VerticalOptions="End" />
                        <Label Grid.Row="2" Style="{StaticResource KpiEtiket}" Text="Toplam Öğrenci" />
                    </Grid>
                </Border>

                <!-- Toplam öğretmen -->
                <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource KpiKart}">
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,2" Radius="8" Opacity="0.06" />
                    </Border.Shadow>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding OgretmenlerGitCommand}" />
                    </Border.GestureRecognizers>
                    <Grid Padding="14" RowDefinitions="Auto,*,Auto">
                        <Border Grid.Row="0" BackgroundColor="{StaticResource AdminSoft}" StrokeThickness="0"
                                StrokeShape="RoundRectangle 12" WidthRequest="44" HeightRequest="44" HorizontalOptions="Start">
                            <Label Text="&#x1F468;&#x200D;&#x1F3EB;" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>
                        <Label Grid.Row="1" Style="{StaticResource KpiSayi}"
                               Text="{Binding OgretmenSayisi}" VerticalOptions="End" />
                        <Label Grid.Row="2" Style="{StaticResource KpiEtiket}" Text="Toplam Öğretmen" />
                    </Grid>
                </Border>

                <!-- Toplam sınıf -->
                <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource KpiKart}">
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,2" Radius="8" Opacity="0.06" />
                    </Border.Shadow>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SiniflaraGitCommand}" />
                    </Border.GestureRecognizers>
                    <Grid Padding="14" RowDefinitions="Auto,*,Auto">
                        <Border Grid.Row="0" BackgroundColor="{StaticResource AdminSoft}" StrokeThickness="0"
                                StrokeShape="RoundRectangle 12" WidthRequest="44" HeightRequest="44" HorizontalOptions="Start">
                            <Label Text="&#x1F3EB;" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>
                        <Label Grid.Row="1" Style="{StaticResource KpiSayi}"
                               Text="{Binding SinifSayisi}" VerticalOptions="End" />
                        <Label Grid.Row="2" Style="{StaticResource KpiEtiket}" Text="Toplam Sınıf" />
                    </Grid>
                </Border>

                <!-- Toplam veli -->
                <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource KpiKart}">
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,2" Radius="8" Opacity="0.06" />
                    </Border.Shadow>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding VelilereGitCommand}" />
                    </Border.GestureRecognizers>
                    <Grid Padding="14" RowDefinitions="Auto,*,Auto">
                        <Border Grid.Row="0" BackgroundColor="{StaticResource AdminSoft}" StrokeThickness="0"
                                StrokeShape="RoundRectangle 12" WidthRequest="44" HeightRequest="44" HorizontalOptions="Start">
                            <Label Text="&#x1F468;&#x200D;&#x1F467;&#x200D;&#x1F466;" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>
                        <Label Grid.Row="1" Style="{StaticResource KpiSayi}"
                               Text="{Binding VeliSayisi}" VerticalOptions="End" />
                        <Label Grid.Row="2" Style="{StaticResource KpiEtiket}" Text="Toplam Veli" />
                    </Grid>
                </Border>

                <!-- Bugün yemekhane giriş -->
                <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource KpiKart}">
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,2" Radius="8" Opacity="0.06" />
                    </Border.Shadow>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding YemakhaneGitCommand}" />
                    </Border.GestureRecognizers>
                    <Grid Padding="14" RowDefinitions="Auto,*,Auto">
                        <Border Grid.Row="0" BackgroundColor="{StaticResource AdminSoft}" StrokeThickness="0"
                                StrokeShape="RoundRectangle 12" WidthRequest="44" HeightRequest="44" HorizontalOptions="Start">
                            <Label Text="&#x1F37D;" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>
                        <Label Grid.Row="1" Style="{StaticResource KpiSayi}"
                               Text="{Binding YemekhaneSayisi}" VerticalOptions="End" />
                        <Label Grid.Row="2" Style="{StaticResource KpiEtiket}" Text="Bugün Yemekhane" />
                    </Grid>
                </Border>

                <!-- Bugün anakapı çıkış -->
                <Border Grid.Row="2" Grid.Column="1" Style="{StaticResource KpiKart}">
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,2" Radius="8" Opacity="0.06" />
                    </Border.Shadow>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding AnakapiGitCommand}" />
                    </Border.GestureRecognizers>
                    <Grid Padding="14" RowDefinitions="Auto,*,Auto">
                        <Border Grid.Row="0" BackgroundColor="{StaticResource AdminSoft}" StrokeThickness="0"
                                StrokeShape="RoundRectangle 12" WidthRequest="44" HeightRequest="44" HorizontalOptions="Start">
                            <Label Text="&#x1F6AA;" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>
                        <Label Grid.Row="1" Style="{StaticResource KpiSayi}"
                               Text="{Binding AnakapiSayisi}" VerticalOptions="End" />
                        <Label Grid.Row="2" Style="{StaticResource KpiEtiket}" Text="Bugün Anakapı Çıkış" />
                    </Grid>
                </Border>

                <!-- Toplam servis -->
                <Border Grid.Row="3" Grid.Column="0" Style="{StaticResource KpiKart}">
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,2" Radius="8" Opacity="0.06" />
                    </Border.Shadow>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ServisGitCommand}" />
                    </Border.GestureRecognizers>
                    <Grid Padding="14" RowDefinitions="Auto,*,Auto">
                        <Border Grid.Row="0" BackgroundColor="{StaticResource AdminSoft}" StrokeThickness="0"
                                StrokeShape="RoundRectangle 12" WidthRequest="44" HeightRequest="44" HorizontalOptions="Start">
                            <Label Text="&#x1F68C;" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>
                        <Label Grid.Row="1" Style="{StaticResource KpiSayi}"
                               Text="{Binding ServisSayisi}" VerticalOptions="End" />
                        <Label Grid.Row="2" Style="{StaticResource KpiEtiket}" Text="Toplam Servis" />
                    </Grid>
                </Border>

            </Grid>
        </Grid>
    </ScrollView>
</ContentPage>
