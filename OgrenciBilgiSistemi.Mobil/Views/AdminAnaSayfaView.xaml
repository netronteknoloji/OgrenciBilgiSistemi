<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:OgrenciBilgiSistemi.Mobil.Views"
             x:Class="OgrenciBilgiSistemi.Mobil.Views.AdminAnaSayfaView"
             Title="Yönetici"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F2F2F2">

    <ScrollView>
        <Grid RowDefinitions="125, Auto, Auto">

            <Border Grid.Row="0"
                    StrokeThickness="0"
                    BackgroundColor="#1F4E79"
                    VerticalOptions="FillAndExpand">
                <Border.Shadow>
                    <Shadow Brush="#1F4E79" Offset="0,4" Radius="15" Opacity="0.4" />
                </Border.Shadow>

                <Grid>
                    <views:AnaBaslikView x:Name="MyHeader"
                                          ShowBack="False"
                                          ShowProfile="True" />

                    <VerticalStackLayout Spacing="2"
                                         VerticalOptions="End"
                                         Margin="20,0,20,35">
                        <Label x:Name="WelcomeLabel"
                               Text="Merhaba"
                               FontSize="18"
                               FontFamily="OpenSansSemibold"
                               TextColor="White" />
                        <Label Text="Yönetici Paneli"
                               FontSize="14"
                               FontFamily="OpenSansSemibold"
                               TextColor="White"
                               Opacity="0.8" />
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <!-- Okul adı bilgisi -->
            <Border Grid.Row="1"
                    Margin="15,-28,15,10"
                    HeightRequest="55"
                    StrokeShape="RoundRectangle 28"
                    StrokeThickness="0"
                    BackgroundColor="White">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,10" Radius="20" Opacity="0.08" />
                </Border.Shadow>
                <Grid ColumnDefinitions="55, *">
                    <Label Grid.Column="0" Text="&#x1F3EB;"
                           VerticalOptions="Center" HorizontalOptions="Center" FontSize="22" />
                    <Label Grid.Column="1" x:Name="OkulAdiLabel"
                           Text="Yükleniyor..."
                           VerticalOptions="Center"
                           FontSize="15"
                           FontFamily="OpenSansSemibold"
                           TextColor="#2C3E50" />
                </Grid>
            </Border>

            <!-- KPI kartları -->
            <Grid Grid.Row="2"
                  Margin="15,5,15,20"
                  ColumnDefinitions="*,*"
                  RowDefinitions="Auto,Auto,Auto"
                  ColumnSpacing="10"
                  RowSpacing="10">

                <!-- Toplam öğrenci -->
                <Border Grid.Row="0" Grid.Column="0"
                        StrokeShape="RoundRectangle 16"
                        StrokeThickness="0"
                        BackgroundColor="White"
                        HeightRequest="120">
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,2" Radius="8" Opacity="0.06" />
                    </Border.Shadow>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnOgrencilerTapped" />
                    </Border.GestureRecognizers>
                    <Grid Padding="14" RowDefinitions="Auto,*,Auto">
                        <Label Grid.Row="0" Text="&#x1F468;&#x200D;&#x1F393;" FontSize="22" />
                        <Label Grid.Row="1" x:Name="OgrenciSayisiLabel"
                               Text="-"
                               FontSize="28"
                               FontFamily="OpenSansSemibold"
                               TextColor="#1F4E79"
                               VerticalOptions="End" />
                        <Label Grid.Row="2" Text="Toplam Öğrenci"
                               FontSize="12" TextColor="#7F8C8D"
                               FontFamily="OpenSansSemibold" />
                    </Grid>
                </Border>

                <!-- Toplam öğretmen -->
                <Border Grid.Row="0" Grid.Column="1"
                        StrokeShape="RoundRectangle 16"
                        StrokeThickness="0"
                        BackgroundColor="White"
                        HeightRequest="120">
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,2" Radius="8" Opacity="0.06" />
                    </Border.Shadow>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnOgretmenlerTapped" />
                    </Border.GestureRecognizers>
                    <Grid Padding="14" RowDefinitions="Auto,*,Auto">
                        <Label Grid.Row="0" Text="&#x1F468;&#x200D;&#x1F3EB;" FontSize="22" />
                        <Label Grid.Row="1" x:Name="OgretmenSayisiLabel"
                               Text="-"
                               FontSize="28"
                               FontFamily="OpenSansSemibold"
                               TextColor="#16A085"
                               VerticalOptions="End" />
                        <Label Grid.Row="2" Text="Toplam Öğretmen"
                               FontSize="12" TextColor="#7F8C8D"
                               FontFamily="OpenSansSemibold" />
                    </Grid>
                </Border>

                <!-- Toplam sınıf -->
                <Border Grid.Row="1" Grid.Column="0"
                        StrokeShape="RoundRectangle 16"
                        StrokeThickness="0"
                        BackgroundColor="White"
                        HeightRequest="120">
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,2" Radius="8" Opacity="0.06" />
                    </Border.Shadow>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnSiniflarTapped" />
                    </Border.GestureRecognizers>
                    <Grid Padding="14" RowDefinitions="Auto,*,Auto">
                        <Label Grid.Row="0" Text="&#x1F3EB;" FontSize="22" />
                        <Label Grid.Row="1" x:Name="SinifSayisiLabel"
                               Text="-"
                               FontSize="28"
                               FontFamily="OpenSansSemibold"
                               TextColor="#8E44AD"
                               VerticalOptions="End" />
                        <Label Grid.Row="2" Text="Toplam Sınıf"
                               FontSize="12" TextColor="#7F8C8D"
                               FontFamily="OpenSansSemibold" />
                    </Grid>
                </Border>

                <!-- Toplam veli -->
                <Border Grid.Row="1" Grid.Column="1"
                        StrokeShape="RoundRectangle 16"
                        StrokeThickness="0"
                        BackgroundColor="White"
                        HeightRequest="120">
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,2" Radius="8" Opacity="0.06" />
                    </Border.Shadow>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnVelilerTapped" />
                    </Border.GestureRecognizers>
                    <Grid Padding="14" RowDefinitions="Auto,*,Auto">
                        <Label Grid.Row="0" Text="&#x1F468;&#x200D;&#x1F467;&#x200D;&#x1F466;" FontSize="22" />
                        <Label Grid.Row="1" x:Name="VeliSayisiLabel"
                               Text="-"
                               FontSize="28"
                               FontFamily="OpenSansSemibold"
                               TextColor="#E67E22"
                               VerticalOptions="End" />
                        <Label Grid.Row="2" Text="Toplam Veli"
                               FontSize="12" TextColor="#7F8C8D"
                               FontFamily="OpenSansSemibold" />
                    </Grid>
                </Border>

                <!-- Bugün yemekhane giriş -->
                <Border Grid.Row="2" Grid.Column="0"
                        StrokeShape="RoundRectangle 16"
                        StrokeThickness="0"
                        BackgroundColor="White"
                        HeightRequest="120">
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,2" Radius="8" Opacity="0.06" />
                    </Border.Shadow>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnYemekhaneTapped" />
                    </Border.GestureRecognizers>
                    <Grid Padding="14" RowDefinitions="Auto,*,Auto">
                        <Label Grid.Row="0" Text="&#x1F37D;" FontSize="22" />
                        <Label Grid.Row="1" x:Name="YemekhaneSayisiLabel"
                               Text="-"
                               FontSize="28"
                               FontFamily="OpenSansSemibold"
                               TextColor="#C0392B"
                               VerticalOptions="End" />
                        <Label Grid.Row="2" Text="Bugün Yemekhane"
                               FontSize="12" TextColor="#7F8C8D"
                               FontFamily="OpenSansSemibold" />
                    </Grid>
                </Border>

                <!-- Bugün anakapı çıkış -->
                <Border Grid.Row="2" Grid.Column="1"
                        StrokeShape="RoundRectangle 16"
                        StrokeThickness="0"
                        BackgroundColor="White"
                        HeightRequest="120">
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,2" Radius="8" Opacity="0.06" />
                    </Border.Shadow>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnAnakapiTapped" />
                    </Border.GestureRecognizers>
                    <Grid Padding="14" RowDefinitions="Auto,*,Auto">
                        <Label Grid.Row="0" Text="&#x1F6AA;" FontSize="22" />
                        <Label Grid.Row="1" x:Name="AnakapiSayisiLabel"
                               Text="-"
                               FontSize="28"
                               FontFamily="OpenSansSemibold"
                               TextColor="#2980B9"
                               VerticalOptions="End" />
                        <Label Grid.Row="2" Text="Bugün Anakapı Çıkış"
                               FontSize="12" TextColor="#7F8C8D"
                               FontFamily="OpenSansSemibold" />
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </ScrollView>
</ContentPage>
