<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:OgrenciBilgiSistemi.Mobil.Views"
             x:Class="OgrenciBilgiSistemi.Mobil.Views.VeliDuyurularView"
             x:Name="SayfaKoku"
             Title="Duyurular"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource UygulamaArkaPlan}">

    <Grid RowDefinitions="125, Auto, *">

        <Border Grid.Row="0" StrokeThickness="0" Background="{StaticResource VeliBaslikGradyan}" VerticalOptions="FillAndExpand">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,4" Radius="15" Opacity="0.18" />
            </Border.Shadow>
            <Grid>
                <views:AnaBaslikView x:Name="MyHeader" ShowBack="True" ShowProfile="False" VurguRenk="{StaticResource VeliRenk}" />
                <VerticalStackLayout Spacing="2" VerticalOptions="End" HorizontalOptions="Center" Margin="20,0,20,35">
                    <Label Text="Duyurular" FontSize="18" FontFamily="OpenSansSemibold" TextColor="White" HorizontalTextAlignment="Center" />
                    <Label Text="{Binding AltBaslik}" FontSize="14" TextColor="White" Opacity="0.8" HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </Grid>
        </Border>

        <!-- Tümünü okundu işaretle -->
        <Border Grid.Row="1" Margin="15,-28,15,10" HeightRequest="48" StrokeShape="RoundRectangle 24"
                StrokeThickness="0" BackgroundColor="{StaticResource Kart}">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,8" Radius="24" Opacity="0.10" />
            </Border.Shadow>
            <Border.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding TumunuOkunduCommand}" />
            </Border.GestureRecognizers>
            <HorizontalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="8">
                <Label Text="Tümünü Okundu İşaretle" FontSize="14" FontFamily="OpenSansSemibold" TextColor="{StaticResource VeliRenk}" VerticalOptions="Center" />
            </HorizontalStackLayout>
        </Border>

        <CollectionView Grid.Row="2" ItemsSource="{Binding Duyurular}" Margin="15,0" SelectionMode="None">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="8" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border StrokeShape="RoundRectangle 14" StrokeThickness="0" Padding="14"
                            BackgroundColor="{Binding ArkaplanRenk}">
                        <Border.Shadow>
                            <Shadow Brush="Black" Offset="0,2" Radius="6" Opacity="0.05" />
                        </Border.Shadow>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding BindingContext.DuyuruTapCommand, Source={x:Reference SayfaKoku}}"
                                CommandParameter="{Binding .}" />
                        </Border.GestureRecognizers>
                        <Grid ColumnDefinitions="4, *, Auto" ColumnSpacing="12">
                            <BoxView Grid.Column="0" BackgroundColor="{Binding SolCizgiRenk}" WidthRequest="4"
                                     VerticalOptions="Fill" HorizontalOptions="Center">
                                <BoxView.Clip>
                                    <RoundRectangleGeometry CornerRadius="2" Rect="0,0,4,80" />
                                </BoxView.Clip>
                            </BoxView>
                            <VerticalStackLayout Grid.Column="1" Spacing="6" VerticalOptions="Center">
                                <Label Text="{Binding Duyuru.Baslik}" FontSize="16" FontFamily="OpenSansSemibold" TextColor="{StaticResource MetinKoyu}" />
                                <Grid ColumnDefinitions="Auto, *, Auto">
                                    <Label Grid.Column="0" Text="{Binding Duyuru.OlusturanAdSoyad}" FontSize="12" TextColor="{StaticResource VeliRenk}" />
                                    <Label Grid.Column="2" Text="{Binding Duyuru.TarihMetni}" FontSize="12" TextColor="{StaticResource MetinSoluk}" />
                                </Grid>
                                <Label Text="{Binding Duyuru.Icerik}" FontSize="13" TextColor="{StaticResource MetinGovde}" LineBreakMode="WordWrap" />
                            </VerticalStackLayout>
                            <BoxView Grid.Column="2" WidthRequest="10" HeightRequest="10" CornerRadius="5"
                                     BackgroundColor="{StaticResource VeliRenk}" VerticalOptions="Center"
                                     IsVisible="{Binding OkunmadiMi}" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="10" Padding="20">
                    <Label Text="Henüz duyuru bulunmuyor." FontSize="16" TextColor="{StaticResource MetinSoluk}" HorizontalOptions="Center" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>
        </CollectionView>
    </Grid>
</ContentPage>
