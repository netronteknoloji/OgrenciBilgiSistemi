<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:OgrenciBilgiSistemi.Mobil.Views"
             x:Class="OgrenciBilgiSistemi.Mobil.Views.AdminOgrenciListeView"
             x:Name="SayfaKoku"
             Title="Öğrenciler"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource UygulamaArkaPlan}">

    <Grid RowDefinitions="Auto, *">

        <views:ListeBaslikView Grid.Row="0"
                               Baslik="Öğrenciler"
                               AltBaslik="{Binding AltBaslik}"
                               AramaGoster="True"
                               AramaMetni="{Binding AramaMetni}"
                               AramaPlaceholder="İsim veya öğrenci no ile ara..."
                               BaslikGradyan="{StaticResource AdminBaslikGradyan}"
                               VurguRenk="{StaticResource AdminRenk}"
                               ShowBack="True"
                               ShowProfile="False" />

        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding FiltreliOgrenciler}"
                        Margin="15,10"
                        SelectionMode="None">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="8" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border StrokeShape="RoundRectangle 16" StrokeThickness="0" Padding="14"
                            BackgroundColor="{StaticResource Kart}">
                        <Border.Shadow>
                            <Shadow Brush="Black" Offset="0,2" Radius="8" Opacity="0.06" />
                        </Border.Shadow>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding BindingContext.OgrenciSecCommand, Source={x:Reference SayfaKoku}}"
                                CommandParameter="{Binding .}" />
                        </Border.GestureRecognizers>
                        <Grid ColumnDefinitions="4, *, Auto" ColumnSpacing="12">
                            <Border Grid.Column="0" StrokeThickness="0" StrokeShape="RoundRectangle 2"
                                    BackgroundColor="{StaticResource AdminRenk}" WidthRequest="4"
                                    VerticalOptions="Fill" HorizontalOptions="Center" />
                            <VerticalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center">
                                <Label Text="{Binding OgrenciAdSoyad}" FontSize="15" FontFamily="OpenSansSemibold" TextColor="{StaticResource MetinKoyu}" />
                                <Label Text="{Binding OgrenciNo, StringFormat='Öğrenci No: {0}'}" FontSize="12" TextColor="{StaticResource MetinSoluk}" />
                            </VerticalStackLayout>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="10" Padding="20">
                    <Label Text="{Binding BosDurum}" FontSize="16" TextColor="{StaticResource MetinSoluk}" HorizontalOptions="Center" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>
        </CollectionView>
    </Grid>
</ContentPage>
