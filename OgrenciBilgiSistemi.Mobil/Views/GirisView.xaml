<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="OgrenciBilgiSistemi.Mobil.Views.GirisView"
             Title="Giriş"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource UygulamaArkaPlan}">

    <Grid>
        <BoxView Grid.RowSpan="2"
                 Background="{StaticResource MarkaGradyan}" />

        <ScrollView VerticalOptions="Center">

            <VerticalStackLayout Spacing="0"
                                 Padding="30">

                <VerticalStackLayout Spacing="10"
                                     Margin="0,0,0,40"
                                     HorizontalOptions="Center">

                    <Border StrokeShape="RoundRectangle 50"
                            HeightRequest="100"
                            WidthRequest="100"
                            BackgroundColor="Transparent"
                            StrokeThickness="0">

                        <Border.Shadow>
                            <Shadow Brush="Black"
                                    Offset="0,10"
                                    Radius="20"
                                    Opacity="0.2" />
                        </Border.Shadow>

                        <Image Source="app_logo.png"
                               HeightRequest="100"
                               WidthRequest="100"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"
                               Aspect="AspectFit" />
                    </Border>

                    <Label Text="Öğrenci Bilgi Sistemi"
                           FontSize="28"
                           TextColor="White"
                           FontAttributes="Bold"
                           HorizontalOptions="Center" />

                    <Label Text="Giriş Ekranı"
                           FontSize="14"
                           TextColor="White"
                           Opacity="0.8"
                           HorizontalOptions="Center" />

                </VerticalStackLayout>

                <Border BackgroundColor="{StaticResource Kart}"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 20"
                        Padding="25">

                    <Border.Shadow>
                        <Shadow Brush="Black"
                                Offset="0,20"
                                Radius="30"
                                Opacity="0.12" />
                    </Border.Shadow>

                    <VerticalStackLayout Spacing="20">

                        <Label Text="Hoş Geldiniz"
                               Style="{StaticResource Baslik}"
                               Margin="0,0,0,10"/>

                        <!-- Okul seçimi -->
                        <VerticalStackLayout Spacing="5">

                            <Label Text="Okul"
                                   Style="{StaticResource Etiket}"
                                   Margin="5,0"/>

                            <Border Style="{StaticResource GirdiCerceve}">

                                <Picker Title="Okul Seçiniz"
                                        TextColor="{StaticResource MetinKoyu}"
                                        TitleColor="{StaticResource MetinSoluk}"
                                        BackgroundColor="Transparent"
                                        Margin="12,0"
                                        VerticalOptions="Center"
                                        ItemsSource="{Binding OkulAdlari}"
                                        SelectedIndex="{Binding SecilenOkulIndex}" />
                            </Border>

                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="5">

                            <Label Text="Kullanıcı Adı"
                                   Style="{StaticResource Etiket}"
                                   Margin="5,0"/>

                            <Border Style="{StaticResource GirdiCerceve}">

                                <Entry x:Name="TxtKullaniciAdi"
                                       StyleId="kullaniciAdiEntry"
                                       Placeholder="Kullanıcı adınızı giriniz"
                                       PlaceholderColor="{StaticResource MetinSoluk}"
                                       TextColor="{StaticResource MetinKoyu}"
                                       FontSize="14"
                                       BackgroundColor="Transparent"
                                       Margin="12,0"
                                       VerticalOptions="Center"
                                       Keyboard="Text"
                                       ReturnType="Next"
                                       IsTextPredictionEnabled="False"
                                       IsSpellCheckEnabled="False"
                                       Text="{Binding KullaniciAdi}" />
                            </Border>

                            <!-- Kullanıcı adı öneri listesi -->
                            <Border IsVisible="{Binding OneriListesiGorunur}"
                                    Stroke="{StaticResource CizgiBrush}"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 8"
                                    BackgroundColor="{StaticResource Kart}"
                                    HeightRequest="{Binding OneriKutusuYuksekligi}"
                                    Margin="0,-5,0,0">
                                <CollectionView SelectionMode="Single"
                                                SelectionChanged="OnOneriSecildi"
                                                ItemsSource="{Binding OneriListesi}"
                                                HeightRequest="{Binding OneriKutusuYuksekligi}"
                                                VerticalScrollBarVisibility="Always">
                                    <CollectionView.ItemsLayout>
                                        <LinearItemsLayout Orientation="Vertical" ItemSpacing="0" />
                                    </CollectionView.ItemsLayout>
                                    <CollectionView.ItemTemplate>
                                        <DataTemplate x:DataType="x:String">
                                            <Grid Padding="12,10">
                                                <Label Text="{Binding .}"
                                                       TextColor="{StaticResource MetinKoyu}"
                                                       FontSize="14" />
                                            </Grid>
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>
                                </CollectionView>
                            </Border>

                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="5">

                            <Label Text="Şifre"
                                   Style="{StaticResource Etiket}"
                                   Margin="5,0"/>

                            <Border Style="{StaticResource GirdiCerceve}">

                                <Grid ColumnDefinitions="*, Auto">

                                    <Entry x:Name="TxtPassword"
                                           Grid.Column="0"
                                           Placeholder="••••••••"
                                           IsPassword="{Binding SifreGizli}"
                                           PlaceholderColor="{StaticResource MetinSoluk}"
                                           TextColor="{StaticResource MetinKoyu}"
                                           FontSize="14"
                                           BackgroundColor="Transparent"
                                           Margin="12,0"
                                           VerticalOptions="Center"
                                           Text="{Binding Sifre}" />

                                    <ImageButton Grid.Column="1"
                                                 Source="{Binding SifreIkonKaynagi}"
                                                 HeightRequest="25"
                                                 WidthRequest="25"
                                                 Margin="0,0,12,0"
                                                 VerticalOptions="Center"
                                                 BackgroundColor="Transparent"
                                                 Command="{Binding SifreToggleCommand}" />
                                </Grid>
                            </Border>

                        </VerticalStackLayout>

                        <HorizontalStackLayout Spacing="5"
                                               Margin="5,-10,0,0"
                                               VerticalOptions="Center">

                            <CheckBox Color="{StaticResource Marka}" IsChecked="{Binding BeniHatirla}" />

                            <Label Text="Beni Hatırla"
                                   Style="{StaticResource Govde}"
                                   VerticalOptions="Center">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding BeniHatirlaToggleCommand}" />
                                </Label.GestureRecognizers>
                            </Label>

                        </HorizontalStackLayout>

                        <Button Text="{Binding GirisButonMetni}"
                                Command="{Binding GirisCommand}"
                                IsEnabled="{Binding GirisButonEtkin}"
                                Style="{StaticResource BirincilButon}"
                                Margin="0,10,0,0">

                            <Button.Shadow>
                                <Shadow Brush="{StaticResource Marka}"
                                        Offset="0,6"
                                        Radius="12"
                                        Opacity="0.35" />
                            </Button.Shadow>
                        </Button>

                    </VerticalStackLayout>
                </Border>

                <Label Text="© 2026 | Developed by Netron Yazılım. Tüm hakları saklıdır."
                       TextColor="White"
                       Opacity="0.6"
                       FontSize="11"
                       HorizontalOptions="Center"
                       Margin="0,40,0,0" />

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
