<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:OgrenciBilgiSistemi.Mobil.Views"
             x:Class="OgrenciBilgiSistemi.Mobil.Views.AdminSinifListeView"
             x:Name="SayfaKoku"
             Title="Sınıflar"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource UygulamaArkaPlan}">

    <Grid RowDefinitions="Auto, *">

        <views:ListeBaslikView Grid.Row="0"
                               Baslik="Sınıflar"
                               AltBaslik="{Binding AltBaslik}"
                               AramaGoster="True"
                               AramaMetni="{Binding AramaMetni}"
                               AramaPlaceholder="Sınıf adı ile ara..."
                               BaslikGradyan="{StaticResource AdminBaslikGradyan}"
                               VurguRenk="{StaticResource AdminRenk}"
                               ShowBack="True"
                               ShowProfile="False" />

        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding FiltreliSiniflar}"
                        Margin="15,10"
                        SelectionMode="None">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="8" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border StrokeShape="RoundRectangle 16" StrokeThickness="0" Padding="14"
                            BackgroundColor="{StaticResource Kart}">
                        <Border.Shadow>
                            <Shadow Brush="Black" Offset="0,2" Radius="8" Opacity="0.06" />
                        </Border.Shadow>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding BindingContext.SinifSecCommand, Source={x:Reference SayfaKoku}}"
                                CommandParameter="{Binding .}" />
                        </Border.GestureRecognizers>
                        <Grid ColumnDefinitions="4, *, Auto" ColumnSpacing="12">
                            <Border Grid.Column="0" StrokeThickness="0" StrokeShape="RoundRectangle 2"
                                    BackgroundColor="{StaticResource AdminRenk}" WidthRequest="4"
                                    VerticalOptions="Fill" HorizontalOptions="Center" />
                            <Label Grid.Column="1" Text="{Binding SinifVerisi.BirimAd}"
                                   FontSize="15" FontFamily="OpenSansSemibold" TextColor="{StaticResource MetinKoyu}"
                                   VerticalOptions="Center" />
                            <Border Grid.Column="2" StrokeShape="RoundRectangle 12" StrokeThickness="0"
                                    BackgroundColor="{StaticResource AdminSoft}" Padding="10,4" VerticalOptions="Center">
                                <Label Text="{Binding OgrenciSayisi, StringFormat='{0} öğrenci'}"
                                       FontSize="12" TextColor="{StaticResource AdminRenk}"
                                       FontFamily="OpenSansSemibold" />
                            </Border>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="10" Padding="20">
                    <Label Text="{Binding BosDurum}" FontSize="16" TextColor="{StaticResource MetinSoluk}" HorizontalOptions="Center" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>
        </CollectionView>
    </Grid>
</ContentPage>
