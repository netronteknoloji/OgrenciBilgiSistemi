<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:OgrenciBilgiSistemi.Mobil.Views"
             x:Class="OgrenciBilgiSistemi.Mobil.Views.RandevuListeView"
             x:Name="SayfaKoku"
             Title="Randevularım"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource UygulamaArkaPlan}">

    <Grid RowDefinitions="125, Auto, *">

        <Border Grid.Row="0" StrokeThickness="0" Background="{StaticResource MarkaGradyan}" VerticalOptions="FillAndExpand">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,4" Radius="15" Opacity="0.18" />
            </Border.Shadow>
            <Grid>
                <views:AnaBaslikView x:Name="MyHeader" ShowBack="True" ShowProfile="False" VurguRenk="{StaticResource Marka}" />
                <VerticalStackLayout Spacing="2" VerticalOptions="End" HorizontalOptions="Center" Margin="20,0,20,35">
                    <Label Text="Randevularım" FontSize="18" FontFamily="OpenSansSemibold" TextColor="White" HorizontalTextAlignment="Center" />
                    <Label x:Name="AltBaslikLabel" Text="Tüm randevularınız" FontSize="14" TextColor="White" Opacity="0.8" HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </Grid>
        </Border>

        <!-- Yeni randevu ve bildirim butonları -->
        <Grid Grid.Row="1" ColumnDefinitions="*, *" Margin="15,-28,15,10" HeightRequest="55">
            <Button Grid.Column="0" Text="+ Yeni Randevu" BackgroundColor="{StaticResource Marka}" TextColor="White"
                    FontFamily="OpenSansSemibold" FontSize="13" CornerRadius="28" Margin="0,0,5,0"
                    Command="{Binding YeniRandevuCommand}" />
            <Button Grid.Column="1" Text="Bildirimler" BackgroundColor="{StaticResource Kart}" TextColor="{StaticResource Marka}"
                    FontFamily="OpenSansSemibold" FontSize="13" CornerRadius="28" Margin="5,0,0,0"
                    Command="{Binding BildirimlerCommand}">
                <Button.Shadow>
                    <Shadow Brush="Black" Offset="0,4" Radius="10" Opacity="0.08" />
                </Button.Shadow>
            </Button>
        </Grid>

        <RefreshView Grid.Row="2" IsRefreshing="{Binding Yenileniyor}" Command="{Binding YenileCommand}">
            <CollectionView Margin="15,0" SelectionMode="None"
                            ItemsSource="{Binding Randevular}"
                            RemainingItemsThreshold="5"
                            RemainingItemsThresholdReachedCommand="{Binding DahaFazlaYukleCommand}">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical" ItemSpacing="10" />
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border StrokeShape="RoundRectangle 16" StrokeThickness="0" BackgroundColor="{StaticResource Kart}" Padding="16">
                            <Border.Shadow>
                                <Shadow Brush="Black" Offset="0,2" Radius="8" Opacity="0.06" />
                            </Border.Shadow>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding BindingContext.RandevuSecCommand, Source={x:Reference SayfaKoku}}"
                                    CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>
                            <Grid ColumnDefinitions="4, *, Auto" ColumnSpacing="14">
                                <BoxView Grid.Column="0" BackgroundColor="{Binding DurumRenk}" WidthRequest="4"
                                         VerticalOptions="Fill" HorizontalOptions="Center">
                                    <BoxView.Clip>
                                        <RoundRectangleGeometry CornerRadius="2" Rect="0,0,4,80" />
                                    </BoxView.Clip>
                                </BoxView>
                                <VerticalStackLayout Grid.Column="1" Spacing="5" VerticalOptions="Center">
                                    <Label Text="{Binding KarsiTarafAdi}" FontSize="16" FontFamily="OpenSansSemibold" TextColor="{StaticResource MetinKoyu}" />
                                    <Label Text="{Binding OgrenciAdSoyad}" FontSize="12" TextColor="{StaticResource MetinSoluk}" IsVisible="{Binding OgrenciGosterilsinMi}" />
                                    <HorizontalStackLayout Spacing="8">
                                        <Label Text="{Binding TarihMetni}" FontSize="12" TextColor="{StaticResource Marka}" />
                                        <Label Text="{Binding SureMetni}" FontSize="12" TextColor="{StaticResource MetinSoluk}" />
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>
                                <Border Grid.Column="2" StrokeShape="RoundRectangle 12" StrokeThickness="0"
                                        BackgroundColor="{Binding DurumArkaplanRenk}" Padding="10,5"
                                        VerticalOptions="Center">
                                    <Label Text="{Binding DurumAdi}" FontSize="11" TextColor="{Binding DurumRenk}" FontFamily="OpenSansSemibold" />
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
                <CollectionView.EmptyView>
                    <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="10" Padding="20">
                        <Label Text="Henüz randevunuz bulunmuyor." FontSize="16" TextColor="{StaticResource MetinSoluk}" HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
            </CollectionView>
        </RefreshView>
    </Grid>
</ContentPage>
