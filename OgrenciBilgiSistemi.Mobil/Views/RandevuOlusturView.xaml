<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:OgrenciBilgiSistemi.Mobil.Views"
             xmlns:models="clr-namespace:OgrenciBilgiSistemi.Mobil.Models"
             x:Class="OgrenciBilgiSistemi.Mobil.Views.RandevuOlusturView"
             Title="Randevu Oluştur"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F0F2F5">

    <Grid RowDefinitions="125, *">

        <Border Grid.Row="0" StrokeThickness="0" BackgroundColor="#27AE60">
            <Border.Shadow>
                <Shadow Brush="#27AE60" Offset="0,4" Radius="15" Opacity="0.4" />
            </Border.Shadow>
            <Grid>
                <views:AnaBaslikView x:Name="MyHeader" ShowBack="True" ShowProfile="False" />
                <VerticalStackLayout Spacing="2" VerticalOptions="End" HorizontalOptions="Center" Margin="20,0,20,15">
                    <Label Text="Yeni Randevu" FontSize="18" FontFamily="OpenSansSemibold" TextColor="White" HorizontalTextAlignment="Center" />
                    <Label Text="{Binding AltBaslikMetni}" FontSize="14" TextColor="White" Opacity="0.8" HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </Grid>
        </Border>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20,20,20,40" Spacing="15">

                <!-- Öğrenci seçimi (Veli için) -->
                <Border StrokeShape="RoundRectangle 16" StrokeThickness="0"
                        BackgroundColor="White" Padding="20" IsVisible="{Binding VeliModuGorunur}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Öğrenci Seçin" FontSize="13" FontAttributes="Bold" TextColor="#7F8C8D" />
                        <Picker Title="Öğrenci seçiniz..." FontSize="14" TextColor="#2C3E50"
                                ItemsSource="{Binding CocukAdlari}"
                                SelectedIndex="{Binding SecilenCocukIndex}"
                                IsEnabled="{Binding CocukPickerEtkin}" />
                    </VerticalStackLayout>
                </Border>

                <!-- Öğretmen seçimi (Veli için — öğrenci seçildikten sonra görünür) -->
                <Border StrokeShape="RoundRectangle 16" StrokeThickness="0"
                        BackgroundColor="White" Padding="20" IsVisible="{Binding OgretmenPickerGorunur}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Öğretmen Seçin" FontSize="13" FontAttributes="Bold" TextColor="#7F8C8D" />
                        <Picker Title="Öğretmen seçiniz..." FontSize="14" TextColor="#2C3E50"
                                ItemsSource="{Binding OgretmenAdlari}"
                                SelectedIndex="{Binding SecilenOgretmenIndex}" />
                        <Label Text="{Binding SinifOgretmeniBilgisi}" FontSize="12" TextColor="#27AE60"
                               IsVisible="{Binding SinifOgretmeniBilgisiGorunur}" />
                    </VerticalStackLayout>
                </Border>

                <!-- Veli seçimi (Öğretmen için) -->
                <Border StrokeShape="RoundRectangle 16" StrokeThickness="0"
                        BackgroundColor="White" Padding="20" IsVisible="{Binding OgretmenModuGorunur}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Öğrenci Seçin" FontSize="13" FontAttributes="Bold" TextColor="#7F8C8D" />
                        <Border HeightRequest="40" StrokeShape="RoundRectangle 20"
                                Stroke="#E5E7EB" StrokeThickness="1" BackgroundColor="#F8F9FA">
                            <Grid ColumnDefinitions="40, *">
                                <Label Grid.Column="0" Text="&#x1F50D;" FontSize="14"
                                       HorizontalOptions="Center" VerticalOptions="Center" TextColor="#7F8C8D" />
                                <Entry Grid.Column="1"
                                       Placeholder="Sınıf veya öğrenci ara" PlaceholderColor="#95A5A6"
                                       FontSize="13" TextColor="#2C3E50"
                                       Text="{Binding SinifAramaMetni}" />
                            </Grid>
                        </Border>
                        <HorizontalStackLayout Spacing="8" IsVisible="{Binding BenimSinifimGorunur}">
                            <CheckBox IsChecked="{Binding BenimSinifimSecili}"
                                      Color="#27AE60" VerticalOptions="Center" />
                            <Label Text="Benim Sınıfım" FontSize="14" FontAttributes="Bold"
                                   TextColor="#2C3E50" VerticalOptions="Center" />
                        </HorizontalStackLayout>
                        <Border StrokeShape="RoundRectangle 8" Stroke="#E5E7EB" StrokeThickness="1" Padding="0">
                            <CollectionView IsGrouped="True"
                                            SelectionMode="Single"
                                            SelectionChanged="OnVeliOgrenciSecildi"
                                            ItemsSource="{Binding OgrenciGruplari}"
                                            HeightRequest="320">
                                <CollectionView.GroupHeaderTemplate>
                                    <DataTemplate x:DataType="models:OgrenciGrubu">
                                        <Grid Padding="12,10" BackgroundColor="#F1F5F9">
                                            <Label Text="{Binding BaslikAdi}" FontSize="14" FontAttributes="Bold" TextColor="#2C3E50" />
                                        </Grid>
                                    </DataTemplate>
                                </CollectionView.GroupHeaderTemplate>
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="models:Ogrenci">
                                        <Grid Padding="16,10">
                                            <Label Text="{Binding OgrenciAdSoyad}" FontSize="14" TextColor="#2C3E50" />
                                        </Grid>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                                <CollectionView.EmptyView>
                                    <Label Text="Öğrenci bulunamadı" HorizontalOptions="Center" Padding="20" TextColor="#7F8C8D" />
                                </CollectionView.EmptyView>
                            </CollectionView>
                        </Border>
                        <Label Text="{Binding SeciliOgrenciMetni}" FontSize="13" TextColor="#16A34A"
                               IsVisible="{Binding SeciliOgrenciGorunur}" />
                    </VerticalStackLayout>
                </Border>

                <!-- Müsait slot seçimi (Veli için) -->
                <Border StrokeShape="RoundRectangle 16" StrokeThickness="0"
                        BackgroundColor="White" Padding="20" IsVisible="{Binding VeliModuGorunur}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Randevu Saati Seçin" FontSize="13" FontAttributes="Bold" TextColor="#7F8C8D" />
                        <CollectionView SelectionMode="Single" HeightRequest="200"
                                        ItemsSource="{Binding SlotListesi}"
                                        SelectionChanged="OnSlotSecildi">
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Vertical" ItemSpacing="5" />
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Border StrokeShape="RoundRectangle 10" StrokeThickness="1" Stroke="#E0E0E0"
                                            BackgroundColor="#F8F9FA" Padding="12,8">
                                        <Label Text="{Binding GosterimMetni}" FontSize="14" TextColor="#2C3E50" />
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                            <CollectionView.EmptyView>
                                <Label Text="Randevu saati bulunamadı." FontSize="13" TextColor="#95A5A6" HorizontalOptions="Center" Margin="0,20" />
                            </CollectionView.EmptyView>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>

                <!-- Tarih ve saat seçimi (Öğretmen için) -->
                <Border StrokeShape="RoundRectangle 16" StrokeThickness="0"
                        BackgroundColor="White" Padding="20" IsVisible="{Binding OgretmenModuGorunur}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Tarih ve Saat" FontSize="13" FontAttributes="Bold" TextColor="#7F8C8D" />
                        <DatePicker x:Name="TarihSecici" FontSize="14" TextColor="#2C3E50"
                                    Date="{Binding SecilenTarih}" />
                        <Grid ColumnDefinitions="*, Auto, *" ColumnSpacing="10">
                            <TimePicker Grid.Column="0" FontSize="14" TextColor="#2C3E50"
                                        Time="{Binding BaslangicSaatiSecilen}" />
                            <Label Grid.Column="1" Text="-" FontSize="18" TextColor="#95A5A6" VerticalOptions="Center" />
                            <TimePicker Grid.Column="2" FontSize="14" TextColor="#2C3E50"
                                        Time="{Binding BitisSaatiSecilen}" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Not -->
                <Border StrokeShape="RoundRectangle 16" StrokeThickness="0" BackgroundColor="White" Padding="20">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Not (opsiyonel)" FontSize="13" FontAttributes="Bold" TextColor="#7F8C8D" />
                        <Editor Placeholder="Randevu hakkında not ekleyin..." FontSize="14"
                                TextColor="#2C3E50" HeightRequest="80" Text="{Binding Not}" />
                    </VerticalStackLayout>
                </Border>

                <!-- Oluştur butonu -->
                <Button Text="Randevu Oluştur" BackgroundColor="#27AE60" TextColor="White"
                        FontFamily="OpenSansSemibold" FontSize="16" CornerRadius="12" HeightRequest="52"
                        Command="{Binding OlusturCommand}" IsEnabled="{Binding OlusturButonEtkin}" />

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
