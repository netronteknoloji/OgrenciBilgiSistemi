<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:OgrenciBilgiSistemi.Mobil.Views"
             x:Class="OgrenciBilgiSistemi.Mobil.Views.ServisEkraniView"
             Title="Servis Yoklama"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource UygulamaArkaPlan}">

    <ContentPage.Resources>
        <Style x:Key="ServisDurumBorderStyle" TargetType="Border">
            <Setter Property="StrokeShape" Value="RoundRectangle 12" />
            <Setter Property="StrokeThickness" Value="1" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="BackgroundColor" Value="{StaticResource Kart}" />
            <Setter Property="Stroke" Value="{StaticResource CizgiBrush}" />
        </Style>
    </ContentPage.Resources>

    <Grid RowDefinitions="125, Auto, Auto, Auto, *, Auto">

        <Border Grid.Row="0"
                StrokeThickness="0"
                Background="{StaticResource ServisBaslikGradyan}"
                VerticalOptions="FillAndExpand">
            <Border.Shadow>
                <Shadow Brush="{StaticResource ServisRenk}" Offset="0,4" Radius="15" Opacity="0.35" />
            </Border.Shadow>

            <Grid>
                <views:AnaBaslikView x:Name="MyHeader"
                                      ShowBack="False"
                                      ShowProfile="True"
                                      VurguRenk="{StaticResource ServisRenk}" />

                <VerticalStackLayout Spacing="2"
                                     VerticalOptions="End"
                                     Margin="20,0,20,35">
                    <Label Text="{Binding KarsilamaMetni}"
                           FontSize="18"
                           FontFamily="OpenSansSemibold"
                           TextColor="White" />
                    <Label Text="{Binding PlakaMetni}"
                           FontSize="14"
                           FontFamily="OpenSansSemibold"
                           TextColor="White"
                           Opacity="0.8" />
                </VerticalStackLayout>
            </Grid>
        </Border>

        <!-- Periyot seçici (Sabah / Akşam) -->
        <Border Grid.Row="1"
                Style="{StaticResource YuzenKart}"
                Margin="15,-28,15,10"
                HeightRequest="55"
                StrokeShape="RoundRectangle 28">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,8" Radius="24" Opacity="0.10" />
            </Border.Shadow>
            <Grid ColumnDefinitions="55, *">
                <Label Grid.Column="0" Text="🚌" VerticalOptions="Center" HorizontalOptions="Center" FontSize="22" />
                <Picker Grid.Column="1" Title="Periyot Seçiniz" TitleColor="{StaticResource MetinSoluk}"
                        TextColor="{StaticResource MetinKoyu}" VerticalOptions="Center" SelectedIndex="{Binding SecilenPeriyotIndex}">
                    <Picker.ItemsSource>
                        <x:Array Type="{x:Type x:String}">
                            <x:String>Sabah Servisi</x:String>
                            <x:String>Akşam Servisi</x:String>
                        </x:Array>
                    </Picker.ItemsSource>
                </Picker>
            </Grid>
        </Border>

        <!-- Öğrenci sayısı + Arama -->
        <Border Grid.Row="2"
                Margin="15,0,15,10"
                HeightRequest="45"
                StrokeShape="RoundRectangle 22"
                StrokeThickness="0"
                BackgroundColor="{StaticResource Kart}">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,4" Radius="10" Opacity="0.05" />
            </Border.Shadow>
            <Grid ColumnDefinitions="45, *, Auto">
                <Label Grid.Column="0" Text="🔍" VerticalOptions="Center" HorizontalOptions="Center" FontSize="16" TextColor="{StaticResource MetinSoluk}" />
                <Entry Grid.Column="1" Placeholder="Öğrenci ara..." PlaceholderColor="{StaticResource MetinSoluk}"
                       TextColor="{StaticResource MetinKoyu}" FontSize="14" VerticalOptions="Center" Text="{Binding AramaMetni}" />
                <Label Grid.Column="2" Text="{Binding OgrenciSayisiMetni}"
                       VerticalOptions="Center" FontSize="12" TextColor="{StaticResource MetinSoluk}" Margin="0,0,15,0" />
            </Grid>
        </Border>

        <!-- Uyarı: Daha önce kaydedilmiş yoklama -->
        <Border Grid.Row="3" IsVisible="{Binding StatusUyariGorunur}" Margin="15,0,15,10"
                StrokeShape="RoundRectangle 10" StrokeThickness="0" BackgroundColor="#FFF3CD">
            <Label Text="Bu periyodun yoklaması daha önce kaydedilmiştir." Padding="12"
                   TextColor="#856404" HorizontalOptions="Center" FontSize="13" />
        </Border>

        <!-- Öğrenci listesi (yoklama kartları) -->
        <CollectionView Grid.Row="4" Margin="15,0" SelectionMode="None" ItemsSource="{Binding FiltreliOgrenciler}">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="10" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border StrokeShape="RoundRectangle 16" StrokeThickness="0" BackgroundColor="{StaticResource Kart}" Padding="15">
                        <Border.Shadow>
                            <Shadow Brush="Black" Offset="0,2" Radius="8" Opacity="0.06" />
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="12">
                            <!-- Öğrenci bilgileri -->
                            <Grid ColumnDefinitions="Auto, *" ColumnSpacing="12" VerticalOptions="Center">
                                <Border Grid.Column="0" StrokeShape="RoundRectangle 20" HeightRequest="40"
                                        WidthRequest="40" StrokeThickness="0" BackgroundColor="{StaticResource KartSoluk}">
                                    <Image Aspect="AspectFill" Source="{Binding OgrenciData.OgrenciGorsel, TargetNullValue='user_icon.png', FallbackValue='user_icon.png'}" />
                                </Border>
                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                    <Label Text="{Binding OgrenciData.OgrenciAdSoyad}" FontSize="16"
                                           FontFamily="OpenSansSemibold" TextColor="{StaticResource MetinKoyu}" LineBreakMode="TailTruncation" />
                                    <Label Text="{Binding OgrenciData.SinifAdi}" FontSize="11" TextColor="{StaticResource MetinSoluk}" />
                                </VerticalStackLayout>
                            </Grid>

                            <!-- Durum butonları: Bindi / Binmedi -->
                            <FlexLayout Wrap="Wrap" Direction="Row" JustifyContent="Start">
                                <Border Style="{StaticResource ServisDurumBorderStyle}">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnServisDurumTapped" CommandParameter="1" />
                                    </Border.GestureRecognizers>
                                    <Label Text="Bindi" FontSize="13" TextColor="{StaticResource MetinGovde}">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding ServisDurumId}" Value="1">
                                                <Setter Property="TextColor" Value="White" />
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>
                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border" Binding="{Binding ServisDurumId}" Value="1">
                                            <Setter Property="BackgroundColor" Value="{StaticResource Basari}" />
                                            <Setter Property="Stroke" Value="{StaticResource Basari}" />
                                        </DataTrigger>
                                    </Border.Triggers>
                                </Border>

                                <Border Style="{StaticResource ServisDurumBorderStyle}">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnServisDurumTapped" CommandParameter="2" />
                                    </Border.GestureRecognizers>
                                    <Label Text="Binmedi" FontSize="13" TextColor="{StaticResource MetinGovde}">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding ServisDurumId}" Value="2">
                                                <Setter Property="TextColor" Value="White" />
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>
                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border" Binding="{Binding ServisDurumId}" Value="2">
                                            <Setter Property="BackgroundColor" Value="{StaticResource Tehlike}" />
                                            <Setter Property="Stroke" Value="{StaticResource Tehlike}" />
                                        </DataTrigger>
                                    </Border.Triggers>
                                </Border>
                            </FlexLayout>
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="10" Padding="20">
                    <Label Text="Bu serviste öğrenci bulunmuyor." FontSize="16" TextColor="{StaticResource MetinSoluk}" HorizontalOptions="Center" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>
        </CollectionView>

        <!-- Kaydet / Güncelle butonları -->
        <Border Grid.Row="5" Padding="15,10,15,20" BackgroundColor="{StaticResource Kart}" StrokeThickness="0">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,-5" Radius="10" Opacity="0.05" />
            </Border.Shadow>
            <Grid>
                <Button Text="YOKLAMAYI KAYDET" HeightRequest="54" CornerRadius="14"
                        FontFamily="OpenSansSemibold"
                        BackgroundColor="{StaticResource ServisRenk}" TextColor="White"
                        Command="{Binding KaydetCommand}" IsVisible="{Binding KaydetGorunur}" />
                <Button Text="YOKLAMAYI GÜNCELLE" HeightRequest="54" CornerRadius="14"
                        FontFamily="OpenSansSemibold"
                        BackgroundColor="{StaticResource ServisKoyu}" TextColor="White"
                        Command="{Binding GuncelleCommand}" IsVisible="{Binding GuncelleGorunur}" />
            </Grid>
        </Border>
    </Grid>
</ContentPage>
