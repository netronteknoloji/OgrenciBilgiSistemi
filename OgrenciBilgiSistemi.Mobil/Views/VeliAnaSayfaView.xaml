<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:OgrenciBilgiSistemi.Mobil.Views"
             x:Class="OgrenciBilgiSistemi.Mobil.Views.VeliAnaSayfaView"
             x:Name="SayfaKoku"
             Title="Çocuklarım"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource UygulamaArkaPlan}">

    <Grid RowDefinitions="125, Auto, Auto, *">

        <Border Grid.Row="0"
                StrokeThickness="0"
                Background="{StaticResource VeliBaslikGradyan}"
                VerticalOptions="FillAndExpand">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,4" Radius="15" Opacity="0.18" />
            </Border.Shadow>

            <Grid>
                <views:AnaBaslikView x:Name="MyHeader"
                                      ShowBack="False"
                                      ShowProfile="True"
                                      VurguRenk="{StaticResource VeliRenk}" />

                <VerticalStackLayout Spacing="2"
                                     VerticalOptions="End"
                                     Margin="20,0,20,35">
                    <Label Text="{Binding KarsilamaMetni}"
                           FontSize="18"
                           FontFamily="OpenSansSemibold"
                           TextColor="White" />
                    <Label Text="Veli Paneli"
                           FontSize="14"
                           FontFamily="OpenSansSemibold"
                           TextColor="White"
                           Opacity="0.8" />
                </VerticalStackLayout>
            </Grid>
        </Border>

        <!-- Çocuk sayısı bilgisi -->
        <Border Grid.Row="1"
                Style="{StaticResource YuzenKart}"
                Margin="15,-28,15,10"
                HeightRequest="55"
                StrokeShape="RoundRectangle 28">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,8" Radius="24" Opacity="0.10" />
            </Border.Shadow>
            <Grid ColumnDefinitions="55, *, Auto, Auto">
                <Label Grid.Column="0" Text="&#x1F468;&#x200D;&#x1F467;&#x200D;&#x1F466;"
                       VerticalOptions="Center" HorizontalOptions="Center" FontSize="22" />
                <Label Grid.Column="1" Text="{Binding CocukSayisiMetni}"
                       VerticalOptions="Center"
                       FontSize="15"
                       FontFamily="OpenSansSemibold"
                       TextColor="{StaticResource MetinKoyu}" />
                <Border Grid.Column="2" StrokeShape="RoundRectangle 14" StrokeThickness="0"
                        BackgroundColor="{StaticResource VeliRenk}" Padding="10,5" Margin="0,0,5,0"
                        VerticalOptions="Center">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding RandevularCommand}" />
                    </Border.GestureRecognizers>
                    <Label Text="Randevular" FontSize="11" TextColor="White" FontFamily="OpenSansSemibold" />
                </Border>
                <Grid Grid.Column="3" VerticalOptions="Center" Margin="0,0,10,0">
                    <Border StrokeShape="RoundRectangle 14" StrokeThickness="0"
                            BackgroundColor="{StaticResource VeliKoyu}" Padding="10,5">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding BildirimlerCommand}" />
                        </Border.GestureRecognizers>
                        <Label Text="Bildirimler" FontSize="11" TextColor="White" FontFamily="OpenSansSemibold" />
                    </Border>
                    <Border StrokeShape="RoundRectangle 8" StrokeThickness="0"
                            BackgroundColor="{StaticResource Tehlike}" WidthRequest="16" HeightRequest="16"
                            HorizontalOptions="End" VerticalOptions="Start" Margin="0,-6,-6,0"
                            IsVisible="{Binding BildirimBadgeGorunur}">
                        <Label Text="{Binding BildirimSayiMetni}" FontSize="8" TextColor="White"
                               HorizontalOptions="Center" VerticalOptions="Center" />
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <!-- Duyurular butonu -->
        <Grid Grid.Row="2" Margin="15,0,15,10">
            <Border StrokeShape="RoundRectangle 14" StrokeThickness="0"
                    BackgroundColor="{StaticResource VeliRenk}" Padding="12,10" HeightRequest="42">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding DuyurularCommand}" />
                </Border.GestureRecognizers>
                <Grid ColumnDefinitions="Auto, *, Auto" VerticalOptions="Center">
                    <Label Grid.Column="0" Text="&#x1F4E2;" FontSize="18" VerticalOptions="Center" />
                    <Label Grid.Column="1" Text="Duyurular" FontSize="14" TextColor="White"
                           FontFamily="OpenSansSemibold" Margin="10,0,0,0" VerticalOptions="Center" />
                    <Label Grid.Column="2" Text="&#x2192;" FontSize="18" TextColor="White" VerticalOptions="Center" />
                </Grid>
            </Border>
            <Border StrokeShape="RoundRectangle 8" StrokeThickness="0"
                    BackgroundColor="{StaticResource Tehlike}" WidthRequest="16" HeightRequest="16"
                    HorizontalOptions="End" VerticalOptions="Start" Margin="0,-6,-6,0"
                    IsVisible="{Binding DuyuruBadgeGorunur}">
                <Label Text="{Binding DuyuruSayiMetni}" FontSize="8" TextColor="White"
                       HorizontalOptions="Center" VerticalOptions="Center" />
            </Border>
        </Grid>

        <!-- Çocuk listesi -->
        <CollectionView Grid.Row="3" Margin="15,0" SelectionMode="None" ItemsSource="{Binding Cocuklar}">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="10" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border StrokeShape="RoundRectangle 16" StrokeThickness="0" BackgroundColor="{StaticResource Kart}" Padding="0">
                        <Border.Shadow>
                            <Shadow Brush="Black" Offset="0,2" Radius="8" Opacity="0.06" />
                        </Border.Shadow>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding BindingContext.CocukSecCommand, Source={x:Reference SayfaKoku}}"
                                CommandParameter="{Binding .}" />
                        </Border.GestureRecognizers>
                        <Grid ColumnDefinitions="8, 65, *, Auto" Padding="0,12">
                            <BoxView Grid.Column="0" Color="{StaticResource VeliRenk}" WidthRequest="8" HorizontalOptions="Start" />
                            <Border Grid.Column="1" StrokeShape="RoundRectangle 25" StrokeThickness="0"
                                    WidthRequest="50" HeightRequest="50" Margin="8,0">
                                <Image Source="{Binding OgrenciGorsel}" Aspect="AspectFill"
                                       WidthRequest="50" HeightRequest="50" />
                            </Border>
                            <VerticalStackLayout Grid.Column="2" VerticalOptions="Center" Spacing="3">
                                <Label Text="{Binding OgrenciAdSoyad}" FontSize="16" FontFamily="OpenSansSemibold" TextColor="{StaticResource MetinKoyu}" />
                                <Label Text="{Binding SinifAdi}" FontSize="12" TextColor="{StaticResource MetinSoluk}" />
                            </VerticalStackLayout>
                            <Label Grid.Column="3" Text="&#x2192;" FontSize="22" TextColor="{StaticResource VeliRenk}" VerticalOptions="Center" Margin="0,0,15,0" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="10" Padding="20">
                    <Label Text="Kayıtlı öğrenci bulunamadı." FontSize="16" TextColor="{StaticResource MetinSoluk}" HorizontalOptions="Center" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>
        </CollectionView>
    </Grid>
</ContentPage>
