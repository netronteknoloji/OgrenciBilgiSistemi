<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:OgrenciBilgiSistemi.Mobil.Views"
             xmlns:models="clr-namespace:OgrenciBilgiSistemi.Mobil.Models"
             x:Class="OgrenciBilgiSistemi.Mobil.Views.AdminServisDetayView"
             x:Name="SayfaKoku"
             Title="Servis Detayı"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource UygulamaArkaPlan}">

    <Grid RowDefinitions="125, *">

        <Border Grid.Row="0" StrokeThickness="0" Background="{StaticResource AdminBaslikGradyan}" VerticalOptions="FillAndExpand">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,4" Radius="15" Opacity="0.18" />
            </Border.Shadow>
            <Grid>
                <views:AnaBaslikView ShowBack="True" ShowProfile="False" VurguRenk="{StaticResource AdminRenk}" />
                <VerticalStackLayout Spacing="2" VerticalOptions="End" HorizontalOptions="Center" Margin="20,0,20,15">
                    <Label Text="Servis Detayı" FontSize="18" FontFamily="OpenSansSemibold" TextColor="White" HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </Grid>
        </Border>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="0" Padding="0,0,0,20">

            <!-- Servis Bilgi Kartı -->
            <Border Margin="15,15,15,10"
                    StrokeShape="RoundRectangle 16"
                    StrokeThickness="0"
                    BackgroundColor="{StaticResource Kart}"
                    Padding="18">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,4" Radius="12" Opacity="0.10" />
                </Border.Shadow>
                <VerticalStackLayout Spacing="14">

                    <Grid ColumnDefinitions="60,*">
                        <Border Grid.Column="0"
                                StrokeShape="RoundRectangle 14"
                                StrokeThickness="0"
                                BackgroundColor="{StaticResource AdminSoft}"
                                HeightRequest="50"
                                WidthRequest="50"
                                VerticalOptions="Center">
                            <Label Text="&#x1F68C;"
                                   FontSize="26"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                        </Border>
                        <VerticalStackLayout Grid.Column="1" Margin="14,0,0,0" VerticalOptions="Center" Spacing="2">
                            <Label Text="{Binding AdSoyad}"
                                   FontSize="18"
                                   FontFamily="OpenSansSemibold"
                                   TextColor="{StaticResource MetinKoyu}" />
                        </VerticalStackLayout>
                    </Grid>

                    <BoxView HeightRequest="1" BackgroundColor="{StaticResource Cizgi}" />

                    <Grid ColumnDefinitions="100,*" RowDefinitions="Auto,Auto,Auto" RowSpacing="10">
                        <Label Grid.Row="0" Grid.Column="0" Text="Plaka" FontSize="13" TextColor="{StaticResource MetinSoluk}" FontFamily="OpenSansSemibold" />
                        <Label Grid.Row="0" Grid.Column="1" Text="{Binding Plaka}" FontSize="14" TextColor="{StaticResource MetinKoyu}" />

                        <Label Grid.Row="1" Grid.Column="0" Text="Telefon" FontSize="13" TextColor="{StaticResource MetinSoluk}" FontFamily="OpenSansSemibold" />
                        <Label Grid.Row="1" Grid.Column="1" Text="{Binding Telefon}" FontSize="14" TextColor="{StaticResource AdminRenk}" FontFamily="OpenSansSemibold">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding TelefonAraCommand}" />
                            </Label.GestureRecognizers>
                        </Label>

                        <Label Grid.Row="2" Grid.Column="0" Text="Öğrenci" FontSize="13" TextColor="{StaticResource MetinSoluk}" FontFamily="OpenSansSemibold" />
                        <Label Grid.Row="2" Grid.Column="1" Text="{Binding OgrenciSayisiMetni}" FontSize="14" TextColor="{StaticResource MetinKoyu}" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Öğrenciler Başlığı -->
            <Label Text="{Binding OgrencilerBaslik}"
                   FontSize="17"
                   FontFamily="OpenSansSemibold"
                   TextColor="{StaticResource MetinKoyu}"
                   Margin="20,15,20,8" />

            <!-- Öğrenci Listesi -->
            <VerticalStackLayout Margin="15,0,15,0" Spacing="8">
                <BindableLayout.ItemsSource>
                    <Binding Path="Ogrenciler" />
                </BindableLayout.ItemsSource>
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="models:Ogrenci">
                        <Border StrokeShape="RoundRectangle 12"
                                StrokeThickness="0"
                                BackgroundColor="{StaticResource Kart}"
                                Padding="14,10">
                            <Border.Shadow>
                                <Shadow Brush="Black" Offset="0,2" Radius="8" Opacity="0.06" />
                            </Border.Shadow>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding BindingContext.OgrenciSecCommand, Source={x:Reference SayfaKoku}}"
                                    CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>
                            <Grid ColumnDefinitions="44,*,Auto" RowDefinitions="Auto,Auto" RowSpacing="2">
                                <Border Grid.RowSpan="2"
                                        StrokeShape="RoundRectangle 22"
                                        StrokeThickness="0"
                                        BackgroundColor="{StaticResource AdminSoft}"
                                        HeightRequest="44"
                                        WidthRequest="44"
                                        VerticalOptions="Center">
                                    <Label Text="&#x1F468;&#x200D;&#x1F393;"
                                           FontSize="18"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center" />
                                </Border>
                                <Label Grid.Column="1" Grid.Row="0"
                                       Text="{Binding OgrenciAdSoyad}"
                                       FontSize="15"
                                       FontFamily="OpenSansSemibold"
                                       TextColor="{StaticResource MetinKoyu}"
                                       Margin="12,0,0,0" />
                                <Label Grid.Column="1" Grid.Row="1"
                                       Text="{Binding OgrenciNo, StringFormat='Öğrenci No: {0}'}"
                                       FontSize="12"
                                       TextColor="{StaticResource MetinSoluk}"
                                       Margin="12,0,0,0" />
                                <Label Grid.Column="2" Grid.RowSpan="2"
                                       Text="›"
                                       FontSize="22"
                                       TextColor="{StaticResource MetinSoluk}"
                                       VerticalOptions="Center" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>

            <Label Text="{Binding DurumYazisi}"
                   FontSize="13"
                   TextColor="{StaticResource MetinSoluk}"
                   Margin="20,10,20,0"
                   IsVisible="{Binding DurumYazisiGorulur}"
                   HorizontalOptions="Center" />

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
