<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="OgrenciBilgiSistemi.Mobil.Views.AnaBaslikView"
             x:Name="this">

    <Grid HeightRequest="90" 
          VerticalOptions="Start" 
          Padding="15,35,15,0" 
          ColumnDefinitions="50, *, 50"
          BackgroundColor="Transparent">

        <Label x:Name="BackBtn"
               Grid.Column="0"
               Text="←"
               FontSize="28"
               FontAttributes="Bold"
               TextColor="White"
               VerticalOptions="Center"
               HorizontalOptions="Start"
               IsVisible="{Binding ShowBack, Source={x:Reference this}}">
            <Label.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnBackClicked" />
            </Label.GestureRecognizers>
        </Label>

        <Grid Grid.Column="2"
              HeightRequest="44"
              WidthRequest="44"
              HorizontalOptions="End"
              VerticalOptions="Center"
              IsVisible="{Binding ShowProfile, Source={x:Reference this}}">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnProfileClicked" />
            </Grid.GestureRecognizers>

            <Border x:Name="ProfileBtn"
                    HeightRequest="40"
                    WidthRequest="40"
                    StrokeShape="RoundRectangle 20"
                    BackgroundColor="White"
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    StrokeThickness="0"
                    InputTransparent="True">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,2" Radius="3" Opacity="0.15" />
                </Border.Shadow>

                <Label x:Name="InitialLabel"
                       Text="{Binding UserInitial, Source={x:Reference this}}"
                       TextColor="#1ABC9C"
                       FontSize="16"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"
                       InputTransparent="True" />
            </Border>
        </Grid>
    </Grid>
</ContentView>