<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:OgrenciBilgiSistemi.Mobil.Views"
             x:Class="OgrenciBilgiSistemi.Mobil.Views.OgrenciDetayView"
             BackgroundColor="{StaticResource UygulamaArkaPlan}"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="125, Auto, *">

        <Border Grid.Row="0" StrokeThickness="0" Background="{Binding TemaGradyan}">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,4" Radius="15" Opacity="0.18" />
            </Border.Shadow>
            <views:AnaBaslikView x:Name="MyHeader" ShowBack="True" ShowProfile="False" VurguRenk="{Binding TemaRenk}" />
        </Border>

        <VerticalStackLayout Grid.Row="1" HorizontalOptions="Center" Spacing="10" Margin="0,-70,0,10" ZIndex="1">
            <Border StrokeShape="RoundRectangle 75" HeightRequest="140" WidthRequest="140" StrokeThickness="5" Stroke="White" BackgroundColor="White">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,10" Radius="20" Opacity="0.15" />
                </Border.Shadow>
                <Image Aspect="AspectFill" Source="{Binding OgrenciGorsel}" />
            </Border>
            <Label Text="{Binding OgrenciAdSoyad}" FontSize="26" FontAttributes="Bold" TextColor="{StaticResource MetinKoyu}" HorizontalOptions="Center" />
            <Label Text="{Binding BirimAd}" FontSize="16" TextColor="{StaticResource MetinSoluk}" HorizontalOptions="Center" />
        </VerticalStackLayout>

        <ScrollView Grid.Row="2">
            <VerticalStackLayout Padding="20,10,20,40" Spacing="15">

                <Border StrokeShape="RoundRectangle 20" Padding="0" BackgroundColor="{StaticResource Kart}" StrokeThickness="0">
                    <Grid ColumnDefinitions="*, *" Padding="20">
                        <VerticalStackLayout Grid.Column="0" Spacing="5" HorizontalOptions="Center">
                            <Label Text="Öğrenci No" FontSize="12" TextColor="{StaticResource MetinSoluk}" HorizontalOptions="Center"/>
                            <Label Text="{Binding OgrenciNo}" FontSize="18" FontAttributes="Bold" TextColor="{Binding TemaRenk}" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                        <BoxView Grid.Column="0" WidthRequest="1" BackgroundColor="{StaticResource Cizgi}" HorizontalOptions="End" Margin="0,5"/>
                        <VerticalStackLayout Grid.Column="1" Spacing="5" HorizontalOptions="Center">
                            <Label Text="Kart No" FontSize="12" TextColor="{StaticResource MetinSoluk}" HorizontalOptions="Center"/>
                            <Label Text="{Binding OgrenciKartNo}" FontSize="18" FontAttributes="Bold" TextColor="{StaticResource MetinKoyu}" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <Border StrokeShape="RoundRectangle 20" Padding="20" BackgroundColor="{StaticResource Kart}" StrokeThickness="0">
                    <VerticalStackLayout Spacing="15">
                        <Label Text="Veli İletişim Bilgileri" FontSize="13" FontAttributes="Bold" TextColor="{StaticResource MetinSoluk}" CharacterSpacing="1"/>
                        <BoxView HeightRequest="1" Color="{StaticResource Cizgi}" />

                        <VerticalStackLayout Spacing="5">
                            <Label Text="{Binding VeliAdSoyad}" FontSize="20" FontAttributes="Bold" TextColor="{StaticResource MetinKoyu}" />
                            <HorizontalStackLayout Spacing="8">
                                <Label Text="📞" FontSize="14" VerticalOptions="Center"/>
                                <Label x:Name="LblParentPhone" Text="{Binding VeliTelefon}" FontSize="16" FontAttributes="Bold" TextColor="{Binding TemaRenk}" VerticalOptions="Center">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnPhoneTapped" />
                                    </Label.GestureRecognizers>
                                </Label>
                            </HorizontalStackLayout>
                        </VerticalStackLayout>

                        <Grid ColumnDefinitions="*, *" RowDefinitions="Auto, Auto" ColumnSpacing="10" RowSpacing="20" Padding="0,10">
                            <VerticalStackLayout Grid.Row="0" Grid.Column="0" Spacing="5">
                                <Label Text="📧 E-Posta" FontSize="11" TextColor="{StaticResource MetinSoluk}" FontAttributes="Bold"/>
                                <Label Text="{Binding VeliEmail}" FontSize="13" TextColor="{StaticResource MetinKoyu}" LineBreakMode="TailTruncation"/>
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Row="0" Grid.Column="1" Spacing="5">
                                <Label Text="📍 Adres" FontSize="11" TextColor="{StaticResource MetinSoluk}" FontAttributes="Bold"/>
                                <Label Text="{Binding VeliAdres}" FontSize="12" TextColor="{StaticResource MetinKoyu}" LineBreakMode="WordWrap"/>
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Row="1" Grid.Column="0" Spacing="5">
                                <Label Text="💼 Meslek" FontSize="11" TextColor="{StaticResource MetinSoluk}" FontAttributes="Bold"/>
                                <Label Text="{Binding VeliMeslek}" FontSize="13" TextColor="{StaticResource MetinKoyu}" />
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Row="1" Grid.Column="1" Spacing="5">
                                <Label Text="🏢 İş Yeri" FontSize="11" TextColor="{StaticResource MetinSoluk}" FontAttributes="Bold"/>
                                <Label Text="{Binding VeliIsYeri}" FontSize="13" TextColor="{StaticResource MetinKoyu}" />
                            </VerticalStackLayout>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <Border StrokeShape="RoundRectangle 20" Padding="20" StrokeThickness="0" BackgroundColor="{StaticResource Kart}">
                    <HorizontalStackLayout Spacing="20">
                        <Label Text="🚌" FontSize="24" VerticalOptions="Center" />
                        <VerticalStackLayout VerticalOptions="Center">
                            <Label Text="Okul Servis Plakası" FontSize="13" TextColor="{StaticResource MetinSoluk}" FontAttributes="Bold" />
                            <Label Text="{Binding Plaka}" FontSize="16" TextColor="{Binding TemaRenk}" FontAttributes="Bold" />
                        </VerticalStackLayout>
                    </HorizontalStackLayout>
                </Border>

                <Border StrokeShape="RoundRectangle 20" Padding="20" StrokeThickness="0" BackgroundColor="{StaticResource Kart}">
                    <HorizontalStackLayout Spacing="20">
                        <Label Text="👨‍🏫" FontSize="24" VerticalOptions="Center" />
                        <VerticalStackLayout VerticalOptions="Center">
                            <Label Text="Sınıf Öğretmeni" FontSize="13" TextColor="{StaticResource MetinSoluk}" FontAttributes="Bold" />
                            <Label Text="{Binding OgretmenAdSoyad}" FontSize="13" TextColor="{StaticResource MetinKoyu}" FontAttributes="Bold" />
                        </VerticalStackLayout>
                    </HorizontalStackLayout>
                </Border>

                <Border StrokeShape="RoundRectangle 20" Padding="15" BackgroundColor="{StaticResource Kart}" StrokeThickness="0">
                    <VerticalStackLayout Spacing="15">
                        <Label Text="Haftalık Yoklama Analizi" FontSize="13" FontAttributes="Bold" TextColor="{StaticResource MetinSoluk}" CharacterSpacing="1"/>

                        <Border StrokeShape="RoundRectangle 10" BackgroundColor="{StaticResource KartSoluk}" StrokeThickness="0" HeightRequest="50">
                            <Grid ColumnDefinitions="50, *, 50">
                                <Label Grid.Column="0" Text="◀" TextColor="{Binding TemaRenk}" FontSize="22" HorizontalOptions="Center" VerticalOptions="Center" FontAttributes="Bold">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding OncekiHaftaCommand}" />
                                    </Label.GestureRecognizers>
                                </Label>
                                <Label Grid.Column="1" Text="{Binding HaftaMetni}" HorizontalOptions="Center" VerticalOptions="Center" FontAttributes="Bold" TextColor="{StaticResource MetinKoyu}" FontSize="13"/>
                                <Label Grid.Column="2" Text="▶" TextColor="{Binding TemaRenk}" FontSize="22" HorizontalOptions="Center" VerticalOptions="Center" FontAttributes="Bold">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding SonrakiHaftaCommand}" />
                                    </Label.GestureRecognizers>
                                </Label>
                            </Grid>
                        </Border>

                        <Grid ColumnDefinitions="*, *" Margin="0,5">
                            <HorizontalStackLayout Grid.Column="0" Spacing="5" HorizontalOptions="Center">
                                <Label Text="{Binding YoklamaOraniMetni}" FontSize="20" FontAttributes="Bold" TextColor="{StaticResource Basari}"/>
                                <Label Text="Katılım" FontSize="11" TextColor="{StaticResource MetinSoluk}" VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                            <HorizontalStackLayout Grid.Column="1" Spacing="5" HorizontalOptions="Center">
                                <Label Text="{Binding DevamsizlikMetni}" FontSize="20" FontAttributes="Bold" TextColor="{StaticResource Tehlike}"/>
                                <Label Text="Gelmedi" FontSize="11" TextColor="{StaticResource MetinSoluk}" VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                        </Grid>

                        <Grid x:Name="GridAttendanceMatrix" ColumnDefinitions="20, *, *, *, *, *, *, *" RowDefinitions="25, 30, 30, 30, 30, 30, 30, 30, 30" ColumnSpacing="3" RowSpacing="3">
                            <Label Grid.Row="0" Grid.Column="1" Text="Pzt" HorizontalOptions="Center" FontSize="10" FontAttributes="Bold" TextColor="{StaticResource MetinSoluk}"/>
                            <Label Grid.Row="0" Grid.Column="2" Text="Sal" HorizontalOptions="Center" FontSize="10" FontAttributes="Bold" TextColor="{StaticResource MetinSoluk}"/>
                            <Label Grid.Row="0" Grid.Column="3" Text="Çar" HorizontalOptions="Center" FontSize="10" FontAttributes="Bold" TextColor="{StaticResource MetinSoluk}"/>
                            <Label Grid.Row="0" Grid.Column="4" Text="Per" HorizontalOptions="Center" FontSize="10" FontAttributes="Bold" TextColor="{StaticResource MetinSoluk}"/>
                            <Label Grid.Row="0" Grid.Column="5" Text="Cum" HorizontalOptions="Center" FontSize="10" FontAttributes="Bold" TextColor="{StaticResource MetinSoluk}"/>
                            <Label Grid.Row="0" Grid.Column="6" Text="Cts" HorizontalOptions="Center" FontSize="10" FontAttributes="Bold" TextColor="{StaticResource MetinSoluk}"/>
                            <Label Grid.Row="0" Grid.Column="7" Text="Paz" HorizontalOptions="Center" FontSize="10" FontAttributes="Bold" TextColor="{StaticResource MetinSoluk}"/>

                            <Label Grid.Row="1" Grid.Column="0" Text="1" VerticalOptions="Center" HorizontalOptions="Center" FontSize="10" TextColor="{StaticResource MetinSoluk}"/>
                            <Label Grid.Row="2" Grid.Column="0" Text="2" VerticalOptions="Center" HorizontalOptions="Center" FontSize="10" TextColor="{StaticResource MetinSoluk}"/>
                            <Label Grid.Row="3" Grid.Column="0" Text="3" VerticalOptions="Center" HorizontalOptions="Center" FontSize="10" TextColor="{StaticResource MetinSoluk}"/>
                            <Label Grid.Row="4" Grid.Column="0" Text="4" VerticalOptions="Center" HorizontalOptions="Center" FontSize="10" TextColor="{StaticResource MetinSoluk}"/>
                            <Label Grid.Row="5" Grid.Column="0" Text="5" VerticalOptions="Center" HorizontalOptions="Center" FontSize="10" TextColor="{StaticResource MetinSoluk}"/>
                            <Label Grid.Row="6" Grid.Column="0" Text="6" VerticalOptions="Center" HorizontalOptions="Center" FontSize="10" TextColor="{StaticResource MetinSoluk}"/>
                            <Label Grid.Row="7" Grid.Column="0" Text="7" VerticalOptions="Center" HorizontalOptions="Center" FontSize="10" TextColor="{StaticResource MetinSoluk}"/>
                            <Label Grid.Row="8" Grid.Column="0" Text="8" VerticalOptions="Center" HorizontalOptions="Center" FontSize="10" TextColor="{StaticResource MetinSoluk}"/>

                            <Border Grid.Row="1" Grid.RowSpan="8" Grid.Column="6" BackgroundColor="{StaticResource KartSoluk}" StrokeShape="RoundRectangle 4" StrokeThickness="0">
                                <Label Text="Hafta sonu tatili." Rotation="-90" VerticalOptions="Center" HorizontalOptions="Center" FontSize="8" TextColor="{StaticResource MetinSoluk}" FontAttributes="Bold"/>
                            </Border>
                            <Border Grid.Row="1" Grid.RowSpan="8" Grid.Column="7" BackgroundColor="{StaticResource KartSoluk}" StrokeShape="RoundRectangle 4" StrokeThickness="0">
                                <Label Text="Hafta sonu tatili." Rotation="-90" VerticalOptions="Center" HorizontalOptions="Center" FontSize="8" TextColor="{StaticResource MetinSoluk}" FontAttributes="Bold"/>
                            </Border>
                        </Grid>

                        <BoxView HeightRequest="1" Color="{StaticResource Cizgi}" Margin="0,5" />

                        <FlexLayout Wrap="Wrap" JustifyContent="SpaceEvenly" AlignItems="Center" AlignContent="Center">
                            <!-- Lejant renkleri Shared/Constants/YoklamaRenkleri.cs ile eşleşir
                                 (matris hücreleri o sınıftan boyanır) -->
                            <HorizontalStackLayout Spacing="4" Margin="4">
                                <BoxView Color="#198754" WidthRequest="10" HeightRequest="10" CornerRadius="2"/>
                                <Label Text="Geldi" FontSize="10" TextColor="{StaticResource MetinSoluk}"/>
                            </HorizontalStackLayout>
                            <HorizontalStackLayout Spacing="4" Margin="4">
                                <BoxView Color="#DC3545" WidthRequest="10" HeightRequest="10" CornerRadius="2"/>
                                <Label Text="Gelmedi" FontSize="10" TextColor="{StaticResource MetinSoluk}"/>
                            </HorizontalStackLayout>
                            <HorizontalStackLayout Spacing="4" Margin="4">
                                <BoxView Color="#FFC107" WidthRequest="10" HeightRequest="10" CornerRadius="2"/>
                                <Label Text="Geç Geldi" FontSize="10" TextColor="{StaticResource MetinSoluk}"/>
                            </HorizontalStackLayout>
                            <HorizontalStackLayout Spacing="4" Margin="4">
                                <BoxView Color="#0D6EFD" WidthRequest="10" HeightRequest="10" CornerRadius="2"/>
                                <Label Text="İzinli" FontSize="10" TextColor="{StaticResource MetinSoluk}"/>
                            </HorizontalStackLayout>
                            <HorizontalStackLayout Spacing="4" Margin="4">
                                <BoxView Color="#6F42C1" WidthRequest="10" HeightRequest="10" CornerRadius="2"/>
                                <Label Text="Raporlu" FontSize="10" TextColor="{StaticResource MetinSoluk}"/>
                            </HorizontalStackLayout>
                            <HorizontalStackLayout Spacing="4" Margin="4">
                                <BoxView Color="#212529" WidthRequest="10" HeightRequest="10" CornerRadius="2"/>
                                <Label Text="Nöbetçi" FontSize="10" TextColor="{StaticResource MetinSoluk}"/>
                            </HorizontalStackLayout>
                            <HorizontalStackLayout Spacing="4" Margin="4">
                                <BoxView Color="#6C757D" WidthRequest="10" HeightRequest="10" CornerRadius="2"/>
                                <Label Text="Görevli" FontSize="10" TextColor="{StaticResource MetinSoluk}"/>
                            </HorizontalStackLayout>
                        </FlexLayout>
                    </VerticalStackLayout>
                </Border>

                <Border StrokeShape="RoundRectangle 20" Padding="15" BackgroundColor="{StaticResource Kart}" StrokeThickness="0">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Haftalık Giriş/Çıkış" FontSize="13" FontAttributes="Bold" TextColor="{StaticResource MetinSoluk}" CharacterSpacing="1"/>
                        <BoxView HeightRequest="1" Color="{StaticResource Cizgi}" />
                        <VerticalStackLayout x:Name="LayoutGirisCikis" Spacing="8">
                            <Label Text="Yükleniyor..." FontSize="12" TextColor="{StaticResource MetinSoluk}" HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <Border StrokeShape="RoundRectangle 20" Padding="15" BackgroundColor="{StaticResource Kart}" StrokeThickness="0">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Haftalık Yemekhane" FontSize="13" FontAttributes="Bold" TextColor="{StaticResource MetinSoluk}" CharacterSpacing="1"/>
                        <BoxView HeightRequest="1" Color="{StaticResource Cizgi}" />
                        <VerticalStackLayout x:Name="LayoutYemekhane" Spacing="8">
                            <Label Text="Yükleniyor..." FontSize="12" TextColor="{StaticResource MetinSoluk}" HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <Border StrokeShape="RoundRectangle 20" Padding="15" BackgroundColor="{StaticResource Kart}" StrokeThickness="0">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Haftalık Servis Yoklaması" FontSize="13" FontAttributes="Bold" TextColor="{StaticResource MetinSoluk}" CharacterSpacing="1"/>
                        <BoxView HeightRequest="1" Color="{StaticResource Cizgi}" />
                        <VerticalStackLayout x:Name="LayoutServisYoklama" Spacing="8">
                            <Label Text="Yükleniyor..." FontSize="12" TextColor="{StaticResource MetinSoluk}" HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>