<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:OgrenciBilgiSistemi.Mobil.Views"
             x:Class="OgrenciBilgiSistemi.Mobil.Views.AdminVeliDetayView"
             x:Name="SayfaKoku"
             Title="Veli Detayı"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource UygulamaArkaPlan}">

    <Grid RowDefinitions="125, *">

        <Border Grid.Row="0" StrokeThickness="0" Background="{StaticResource AdminBaslikGradyan}" VerticalOptions="FillAndExpand">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,4" Radius="15" Opacity="0.18" />
            </Border.Shadow>
            <Grid>
                <views:AnaBaslikView ShowBack="True" ShowProfile="False" VurguRenk="{StaticResource AdminRenk}" />
                <VerticalStackLayout Spacing="2" VerticalOptions="End" HorizontalOptions="Center" Margin="20,0,20,15">
                    <Label Text="Veli Detayı" FontSize="18" FontFamily="OpenSansSemibold" TextColor="White" HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </Grid>
        </Border>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="15,15" Spacing="12">

                <!-- Profil kartı -->
                <Border StrokeShape="RoundRectangle 16" StrokeThickness="0" BackgroundColor="{StaticResource Kart}" Padding="18">
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,2" Radius="8" Opacity="0.06" />
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="6">
                        <Label Text="{Binding AdSoyad}" FontSize="17" FontFamily="OpenSansSemibold" TextColor="{StaticResource MetinKoyu}" />
                        <Label Text="{Binding Yakinlik}" FontSize="13" TextColor="{StaticResource MetinSoluk}" />
                    </VerticalStackLayout>
                </Border>

                <!-- İletişim -->
                <Border StrokeShape="RoundRectangle 16" StrokeThickness="0" BackgroundColor="{StaticResource Kart}" Padding="18">
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,2" Radius="8" Opacity="0.06" />
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="14">
                        <Label Text="İletişim" FontSize="14" FontFamily="OpenSansSemibold" TextColor="{StaticResource AdminRenk}" />

                        <VerticalStackLayout Spacing="2">
                            <Label Text="Telefon" FontSize="11" TextColor="{StaticResource MetinSoluk}" />
                            <Label Text="{Binding Telefon}" FontSize="14" TextColor="{StaticResource MetinKoyu}" FontFamily="OpenSansSemibold">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding TelefonAraCommand}" />
                                </Label.GestureRecognizers>
                            </Label>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="2">
                            <Label Text="E-Posta" FontSize="11" TextColor="{StaticResource MetinSoluk}" />
                            <Label Text="{Binding Email}" FontSize="14" TextColor="{StaticResource MetinKoyu}" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="2">
                            <Label Text="Adres" FontSize="11" TextColor="{StaticResource MetinSoluk}" />
                            <Label Text="{Binding Adres}" FontSize="14" TextColor="{StaticResource MetinKoyu}" />
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <!-- İş bilgileri -->
                <Border StrokeShape="RoundRectangle 16" StrokeThickness="0" BackgroundColor="{StaticResource Kart}" Padding="18">
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,2" Radius="8" Opacity="0.06" />
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="14">
                        <Label Text="İş Bilgileri" FontSize="14" FontFamily="OpenSansSemibold" TextColor="{StaticResource AdminRenk}" />

                        <VerticalStackLayout Spacing="2">
                            <Label Text="Meslek" FontSize="11" TextColor="{StaticResource MetinSoluk}" />
                            <Label Text="{Binding Meslek}" FontSize="14" TextColor="{StaticResource MetinKoyu}" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="2">
                            <Label Text="İş Yeri" FontSize="11" TextColor="{StaticResource MetinSoluk}" />
                            <Label Text="{Binding IsYeri}" FontSize="14" TextColor="{StaticResource MetinKoyu}" />
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <!-- Çocuklar -->
                <Border StrokeShape="RoundRectangle 16" StrokeThickness="0" BackgroundColor="{StaticResource Kart}" Padding="18">
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,2" Radius="8" Opacity="0.06" />
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="10">
                        <Label Text="{Binding CocuklarBaslik}" FontSize="14" FontFamily="OpenSansSemibold" TextColor="{StaticResource AdminRenk}" />
                        <CollectionView ItemsSource="{Binding Cocuklar}" SelectionMode="None">
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Vertical" ItemSpacing="6" />
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Border StrokeShape="RoundRectangle 10" StrokeThickness="0" Padding="12,10" BackgroundColor="{StaticResource KartSoluk}">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding BindingContext.CocukSecCommand, Source={x:Reference SayfaKoku}}"
                                                CommandParameter="{Binding .}" />
                                        </Border.GestureRecognizers>
                                        <Grid ColumnDefinitions="4, *, Auto" ColumnSpacing="10">
                                            <BoxView Grid.Column="0" Color="{StaticResource AdminRenk}" WidthRequest="4"
                                                     VerticalOptions="Fill" HorizontalOptions="Center">
                                                <BoxView.Clip>
                                                    <RoundRectangleGeometry CornerRadius="2" Rect="0,0,4,40" />
                                                </BoxView.Clip>
                                            </BoxView>
                                            <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                                <Label Text="{Binding OgrenciAdSoyad}" FontSize="14" FontFamily="OpenSansSemibold" TextColor="{StaticResource MetinKoyu}" />
                                                <Label Text="{Binding BirimAd}" FontSize="11" TextColor="{StaticResource MetinSoluk}" />
                                            </VerticalStackLayout>
                                            <Label Grid.Column="2" Text="{Binding OgrenciNo, StringFormat='No: {0}'}"
                                                   FontSize="11" TextColor="{StaticResource MetinSoluk}" VerticalOptions="Center" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                            <CollectionView.EmptyView>
                                <Label Text="Bu veliye bağlı aktif öğrenci yok." FontSize="12" TextColor="{StaticResource MetinSoluk}" HorizontalOptions="Center" Padding="0,10" />
                            </CollectionView.EmptyView>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>

                <Label Text="{Binding DurumYazisi}" FontSize="13" TextColor="{StaticResource Tehlike}" HorizontalTextAlignment="Center" />
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
