<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:OgrenciBilgiSistemi.Mobil.Views"
             x:Class="OgrenciBilgiSistemi.Mobil.Views.OgretmenDuyuruOlusturView"
             Title="Duyuru Yayınla"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource UygulamaArkaPlan}">

    <Grid RowDefinitions="125, *">

        <Border Grid.Row="0" StrokeThickness="0" Background="{StaticResource OgretmenBaslikGradyan}" VerticalOptions="FillAndExpand">
            <Border.Shadow>
                <Shadow Brush="{StaticResource OgretmenRenk}" Offset="0,4" Radius="15" Opacity="0.35" />
            </Border.Shadow>
            <Grid>
                <views:AnaBaslikView x:Name="MyHeader" ShowBack="True" ShowProfile="False" VurguRenk="{StaticResource OgretmenRenk}" />
                <VerticalStackLayout Spacing="2" VerticalOptions="End" HorizontalOptions="Center" Margin="20,0,20,15">
                    <Label Text="Duyuru Yayınla" FontSize="18" FontFamily="OpenSansSemibold" TextColor="White" HorizontalTextAlignment="Center" />
                    <Label Text="Velilere yeni bir duyuru gönderin" FontSize="14" TextColor="White" Opacity="0.8" HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </Grid>
        </Border>

        <ScrollView Grid.Row="1">
            <Border Style="{StaticResource YuzenKart}" Margin="15,20,15,15" StrokeShape="RoundRectangle 20">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,8" Radius="24" Opacity="0.10" />
                </Border.Shadow>
                <VerticalStackLayout Padding="18" Spacing="14">

                    <Label Text="Başlık" FontSize="13" FontAttributes="Bold" TextColor="{StaticResource MetinSoluk}" />
                    <Border StrokeShape="RoundRectangle 12" Stroke="{StaticResource CizgiBrush}" StrokeThickness="1" BackgroundColor="{StaticResource KartSoluk}">
                        <Entry Placeholder="Duyuru başlığı" Text="{Binding Baslik}"
                               PlaceholderColor="{StaticResource MetinSoluk}"
                               FontSize="14" TextColor="{StaticResource MetinKoyu}" MaxLength="200"
                               BackgroundColor="Transparent" Margin="10,0" />
                    </Border>

                    <Label Text="İçerik" FontSize="13" FontAttributes="Bold" TextColor="{StaticResource MetinSoluk}" />
                    <Border StrokeShape="RoundRectangle 12" Stroke="{StaticResource CizgiBrush}" StrokeThickness="1" BackgroundColor="{StaticResource KartSoluk}">
                        <Editor Placeholder="Duyuru içeriğini buraya yazınız..." Text="{Binding Icerik}"
                                PlaceholderColor="{StaticResource MetinSoluk}"
                                FontSize="14" TextColor="{StaticResource MetinKoyu}" MaxLength="2000"
                                AutoSize="TextChanges" HeightRequest="180"
                                BackgroundColor="Transparent" Margin="10,5" />
                    </Border>

                    <Label Text="{Binding HataMesaji}" TextColor="{StaticResource Tehlike}" FontSize="13" IsVisible="{Binding HataGorunur}" />

                    <Button Text="Yayınla"
                            BackgroundColor="{StaticResource OgretmenRenk}" TextColor="White" FontFamily="OpenSansSemibold"
                            FontSize="15" CornerRadius="12" HeightRequest="48"
                            Command="{Binding YayinlaCommand}" IsEnabled="{Binding ButonEtkin}" />

                </VerticalStackLayout>
            </Border>
        </ScrollView>
    </Grid>
</ContentPage>
