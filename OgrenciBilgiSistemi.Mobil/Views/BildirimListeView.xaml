<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:OgrenciBilgiSistemi.Mobil.Views"
             x:Class="OgrenciBilgiSistemi.Mobil.Views.BildirimListeView"
             x:Name="SayfaKoku"
             Title="Bildirimler"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource UygulamaArkaPlan}">

    <Grid RowDefinitions="125, Auto, *">

        <Border Grid.Row="0" StrokeThickness="0" Background="{Binding TemaGradyan}" VerticalOptions="FillAndExpand">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,4" Radius="15" Opacity="0.18" />
            </Border.Shadow>
            <Grid>
                <views:AnaBaslikView x:Name="MyHeader" ShowBack="True" ShowProfile="False" VurguRenk="{Binding TemaRenk}" />
                <VerticalStackLayout Spacing="2" VerticalOptions="End" HorizontalOptions="Center" Margin="20,0,20,35">
                    <Label Text="Bildirimler" FontSize="18" FontFamily="OpenSansSemibold" TextColor="White" HorizontalTextAlignment="Center" />
                    <Label Text="{Binding AltBaslik}" FontSize="14" TextColor="White" Opacity="0.8" HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </Grid>
        </Border>

        <!-- Tümünü okundu işaretle -->
        <Border Grid.Row="1" Margin="15,-28,15,10" HeightRequest="48" StrokeShape="RoundRectangle 24"
                StrokeThickness="0" BackgroundColor="{StaticResource Kart}">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,8" Radius="24" Opacity="0.10" />
            </Border.Shadow>
            <Border.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding TumunuOkunduCommand}" />
            </Border.GestureRecognizers>
            <HorizontalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="8">
                <Label Text="Tümünü Okundu İşaretle" FontSize="14" FontFamily="OpenSansSemibold" TextColor="{Binding TemaRenk}" VerticalOptions="Center" />
            </HorizontalStackLayout>
        </Border>

        <CollectionView Grid.Row="2" Margin="15,0" SelectionMode="None"
                        ItemsSource="{Binding Bildirimler}"
                        RemainingItemsThreshold="3"
                        RemainingItemsThresholdReachedCommand="{Binding DahaFazlaYukleCommand}">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="8" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border StrokeShape="RoundRectangle 14" StrokeThickness="0" Padding="14"
                            BackgroundColor="{Binding ArkaplanRenk}">
                        <Border.Shadow>
                            <Shadow Brush="Black" Offset="0,2" Radius="6" Opacity="0.05" />
                        </Border.Shadow>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding BindingContext.BildirimTapCommand, Source={x:Reference SayfaKoku}}"
                                CommandParameter="{Binding .}" />
                        </Border.GestureRecognizers>
                        <Grid ColumnDefinitions="4, *, Auto" ColumnSpacing="12">
                            <Border Grid.Column="0" StrokeThickness="0" StrokeShape="RoundRectangle 2"
                                    BackgroundColor="{Binding SolCizgiRenk}" WidthRequest="4"
                                    VerticalOptions="Fill" HorizontalOptions="Center" />
                            <VerticalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center">
                                <Label Text="{Binding Bildirim.Mesaj}" FontSize="14" TextColor="{StaticResource MetinKoyu}"
                                       LineBreakMode="WordWrap" MaxLines="3" />
                                <Label Text="{Binding Bildirim.TarihMetni}" FontSize="11" TextColor="{StaticResource MetinSoluk}" />
                            </VerticalStackLayout>
                            <Border Grid.Column="2" StrokeThickness="0" StrokeShape="RoundRectangle 5"
                                    WidthRequest="10" HeightRequest="10"
                                    BackgroundColor="{Binding BindingContext.TemaRenk, Source={x:Reference SayfaKoku}}" VerticalOptions="Center"
                                    IsVisible="{Binding OkunmadiMi}" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="10" Padding="20">
                    <Label Text="Henüz bildiriminiz bulunmuyor." FontSize="16" TextColor="{StaticResource MetinSoluk}" HorizontalOptions="Center" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>
        </CollectionView>
    </Grid>
</ContentPage>
