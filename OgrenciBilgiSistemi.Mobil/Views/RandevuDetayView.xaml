<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:OgrenciBilgiSistemi.Mobil.Views"
             x:Class="OgrenciBilgiSistemi.Mobil.Views.RandevuDetayView"
             Title="Randevu Detayı"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F0F2F5">

    <Grid RowDefinitions="125, *">

        <Border Grid.Row="0" StrokeThickness="0" BackgroundColor="#2980B9">
            <Border.Shadow>
                <Shadow Brush="#2980B9" Offset="0,4" Radius="15" Opacity="0.4" />
            </Border.Shadow>
            <Grid>
                <views:AnaBaslikView x:Name="MyHeader" ShowBack="True" ShowProfile="False" />
                <VerticalStackLayout Spacing="2" VerticalOptions="End" HorizontalOptions="Center" Margin="20,0,20,15">
                    <Label Text="Randevu Detayı" FontSize="18" FontFamily="OpenSansSemibold" TextColor="White" HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </Grid>
        </Border>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20,15,20,40" Spacing="15">

                <!-- Durum kartı -->
                <Border StrokeShape="RoundRectangle 16" StrokeThickness="0" BackgroundColor="White" Padding="20">
                    <HorizontalStackLayout Spacing="12" HorizontalOptions="Center">
                        <Label Text="{Binding DurumIkon}" FontSize="28" VerticalOptions="Center" />
                        <VerticalStackLayout VerticalOptions="Center">
                            <Label Text="{Binding DurumAdi}" FontSize="18" FontFamily="OpenSansSemibold"
                                   TextColor="{Binding DurumRenk}" />
                            <Label Text="{Binding DurumAciklama}" FontSize="12" TextColor="#95A5A6" />
                        </VerticalStackLayout>
                    </HorizontalStackLayout>
                </Border>

                <!-- Tarih ve süre -->
                <Border StrokeShape="RoundRectangle 16" StrokeThickness="0" BackgroundColor="White" Padding="20">
                    <Grid ColumnDefinitions="*, *">
                        <VerticalStackLayout Grid.Column="0" Spacing="5" HorizontalOptions="Center">
                            <Label Text="Tarih / Saat" FontSize="12" TextColor="#95A5A6" HorizontalOptions="Center" />
                            <Label Text="{Binding TarihMetni}" FontSize="16" FontAttributes="Bold" TextColor="#2980B9" HorizontalOptions="Center" />
                        </VerticalStackLayout>
                        <BoxView Grid.Column="0" WidthRequest="1" BackgroundColor="#ECF0F1" HorizontalOptions="End" Margin="0,5" />
                        <VerticalStackLayout Grid.Column="1" Spacing="5" HorizontalOptions="Center">
                            <Label Text="Süre" FontSize="12" TextColor="#95A5A6" HorizontalOptions="Center" />
                            <Label Text="{Binding SureMetni}" FontSize="16" FontAttributes="Bold" TextColor="#34495E" HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <!-- Kişi bilgileri -->
                <Border StrokeShape="RoundRectangle 16" StrokeThickness="0" BackgroundColor="White" Padding="20">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Katılımcılar" FontSize="13" FontAttributes="Bold" TextColor="#7F8C8D" CharacterSpacing="1" />
                        <BoxView HeightRequest="1" Color="#F5F6FA" />
                        <Grid ColumnDefinitions="90, *" RowDefinitions="Auto, Auto, Auto" RowSpacing="10" ColumnSpacing="10">
                            <Label Grid.Row="0" Grid.Column="0" Text="Öğretmen:" FontSize="14" TextColor="#95A5A6" VerticalOptions="Center" />
                            <Label Grid.Row="0" Grid.Column="1" Text="{Binding OgretmenAdi}" FontSize="14" FontAttributes="Bold" TextColor="#2C3E50" VerticalOptions="Center" />
                            <Label Grid.Row="1" Grid.Column="0" Text="Veli:" FontSize="14" TextColor="#95A5A6" VerticalOptions="Center" />
                            <Label Grid.Row="1" Grid.Column="1" Text="{Binding VeliAdi}" FontSize="14" FontAttributes="Bold" TextColor="#2C3E50" VerticalOptions="Center" />
                            <Label Grid.Row="2" Grid.Column="0" Text="Öğrenci:" FontSize="14" TextColor="#95A5A6" VerticalOptions="Center"
                                   IsVisible="{Binding OgrenciGorunur}" />
                            <Label Grid.Row="2" Grid.Column="1" Text="{Binding OgrenciAdi}" FontSize="14" FontAttributes="Bold" TextColor="#2C3E50" VerticalOptions="Center"
                                   IsVisible="{Binding OgrenciGorunur}" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Not -->
                <Border StrokeShape="RoundRectangle 16" StrokeThickness="0" BackgroundColor="White" Padding="20"
                        IsVisible="{Binding NotGorunur}">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Not" FontSize="13" FontAttributes="Bold" TextColor="#7F8C8D" />
                        <Label Text="{Binding NotMetni}" FontSize="14" TextColor="#2C3E50" />
                    </VerticalStackLayout>
                </Border>

                <!-- Aksiyon butonları -->
                <VerticalStackLayout Spacing="10" IsVisible="{Binding AksiyonGorunur}">
                    <Button Text="Onayla" BackgroundColor="#27AE60" TextColor="White"
                            FontFamily="OpenSansSemibold" CornerRadius="12" HeightRequest="48"
                            Command="{Binding OnaylaCommand}" IsVisible="{Binding OnaylaGorunur}" />
                    <Button Text="Reddet" BackgroundColor="#E74C3C" TextColor="White"
                            FontFamily="OpenSansSemibold" CornerRadius="12" HeightRequest="48"
                            Command="{Binding ReddetCommand}" IsVisible="{Binding ReddetGorunur}" />
                    <Button Text="İptal Et" BackgroundColor="#95A5A6" TextColor="White"
                            FontFamily="OpenSansSemibold" CornerRadius="12" HeightRequest="48"
                            Command="{Binding IptalCommand}" IsVisible="{Binding IptalGorunur}" />
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
