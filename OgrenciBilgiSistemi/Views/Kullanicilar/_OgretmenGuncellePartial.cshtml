@model OgrenciBilgiSistemi.ViewModels.OgretmenKullaniciFormVm

<div class="viewport-scroller">
    <div class="fixed-canvas">
        <div class="container py-4">
            <div class="row justify-content-center">
                <div class="col-8">
                    <div class="card rounded-3 border">
                        <div class="card-header bg-primary text-white text-center">
                            <h4 class="fw-bold mb-0">Kullanıcı Güncelle (Öğretmen)</h4>
                        </div>

                        <div class="card-body p-4">
                            <form method="post" asp-action="GuncelleOgretmen" autocomplete="off" enctype="multipart/form-data">
                                @Html.AntiForgeryToken()
                                <input type="hidden" asp-for="KullaniciId" />
                                <input type="hidden" asp-for="Rol" />
                                <input type="hidden" asp-for="ReturnPage" />
                                <input type="hidden" asp-for="ReturnFilter" />

                                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                                <div class="row g-3">
                                    <div class="col-6">
                                        <div class="mb-3">
                                            <label asp-for="KullaniciAdi" class="form-label fw-semibold">Kullanıcı Adı</label>
                                            <input asp-for="KullaniciAdi" class="form-control" required minlength="3" placeholder="Kullanıcı adı giriniz" />
                                            <span asp-validation-for="KullaniciAdi" class="text-danger"></span>
                                        </div>

                                        <div class="mb-3">
                                            <label asp-for="Sifre" class="form-label fw-semibold">Şifre</label>
                                            <input asp-for="Sifre" class="form-control" type="password" data-val="false"
                                                   placeholder="Değiştirmek istemiyorsanız boş bırakın" />
                                            <small class="text-muted">Boş bırakırsanız mevcut şifre korunur.</small>
                                            <span asp-validation-for="Sifre" class="text-danger"></span>
                                        </div>

                                        <div class="mb-3">
                                            <label asp-for="KullaniciDurum" class="form-label fw-semibold">Kullanıcı Durumu</label>
                                            <select asp-for="KullaniciDurum" class="form-select">
                                                <option value="true">Aktif</option>
                                                <option value="false">Pasif</option>
                                            </select>
                                            <span asp-validation-for="KullaniciDurum" class="text-danger"></span>
                                        </div>

                                        <div class="mb-3">
                                            <label asp-for="Telefon" class="form-label fw-semibold">Telefon</label>
                                            <input asp-for="Telefon" class="form-control" placeholder="5XXXXXXXXX" />
                                            <span asp-validation-for="Telefon" class="text-danger"></span>
                                        </div>
                                    </div>

                                    <div class="col-6">
                                        <div class="mb-3">
                                            <label asp-for="OgretmenEmail" class="form-label fw-semibold">E-posta</label>
                                            <input asp-for="OgretmenEmail" class="form-control" placeholder="ornek@email.com" />
                                            <span asp-validation-for="OgretmenEmail" class="text-danger"></span>
                                        </div>

                                        <div class="mb-3">
                                            <label asp-for="OgretmenBirimId" class="form-label fw-semibold">Birim</label>
                                            <select asp-for="OgretmenBirimId" class="form-select" asp-items="Model.Birimler">
                                                <option value="">-- Birim Seçiniz --</option>
                                            </select>
                                            <span asp-validation-for="OgretmenBirimId" class="text-danger"></span>
                                        </div>

                                        <div class="mb-3">
                                            <label asp-for="OgretmenGorselFile" class="form-label fw-semibold">Fotoğraf</label>
                                            @if (!string.IsNullOrWhiteSpace(Model.OgretmenGorselPath))
                                            {
                                                <div class="mb-2">
                                                    <img src="@Url.Content(Model.OgretmenGorselPath)"
                                                         alt="Mevcut Fotoğraf"
                                                         class="img-thumbnail d-block"
                                                         style="max-height:80px;" />
                                                </div>
                                            }
                                            <input asp-for="OgretmenGorselFile" type="file" class="form-control" accept=".jpg,.jpeg,.png" />
                                            <span asp-validation-for="OgretmenGorselFile" class="text-danger"></span>
                                        </div>
                                    </div>
                                </div>

                                <div class="d-flex justify-content-between gap-2 mt-3">
                                    <a asp-action="Index" class="btn btn-outline-secondary">
                                        <i class="bi bi-arrow-left"></i> Geri Dön
                                    </a>
                                    <button type="submit" class="btn btn-primary fw-bold">
                                        <i class="bi bi-save"></i> Güncelle
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
