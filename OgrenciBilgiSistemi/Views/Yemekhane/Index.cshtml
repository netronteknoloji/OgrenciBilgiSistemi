@using System.Globalization
@model OgrenciBilgiSistemi.ViewModels.YemekhaneIndexVm

@{
    ViewData["Title"] = "Öğrenci Yemekhane İşlemleri";

    var list = Model.Satirlar;
    var culture = CultureInfo.CurrentCulture;
}

<div class="viewport-scroller">
    <div class="fixed-canvas">
        <div class="card border rounded-4 p-4 mt-4">

            <!-- Başlık -->
            <div class="d-flex justify-content-between align-items-center mb-4 flex-nowrap no-wrap-scroll">
                <h3 class="text-primary fw-bold mb-0">@ViewData["Title"]</h3>
            </div>

            <!-- Filtre Formu -->
            <form id="yemekhaneFilterForm" method="get"
                  asp-controller="Yemekhane" asp-action="Index"
                  class="d-flex align-items-end gap-3 flex-nowrap no-wrap-scroll w-100 bg-body-tertiary border rounded-3 p-3 mb-3">

                <!-- Öğrenci Arama -->
                <div>
                    <label for="query" class="visually-hidden">Öğrenci</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
                        <input asp-for="query" id="query" class="form-control"
                               placeholder="Ad/soyad veya numara…" style="width:280px;" />
                    </div>
                </div>

                <!-- Yıl -->
                <div>
                    <label for="yil" class="visually-hidden">Akademik Yıl</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white"><i class="bi bi-calendar2-week"></i></span>
                        <select asp-for="yil" id="yil" asp-items="Model.Yillar"
                                class="form-select" style="width:160px;"></select>
                    </div>
                </div>

                <!-- Birim -->
                <div>
                    <label for="birimId" class="visually-hidden">Sınıf</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white"><i class="bi bi-diagram-3"></i></span>
                        <select asp-for="birimId" id="birimId" asp-items="Model.Birimler"
                                class="form-select" style="width:190px;"></select>
                    </div>
                </div>

                <!-- Durum -->
                <div>
                    <label for="durum" class="visually-hidden">Durum</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white"><i class="bi bi-funnel"></i></span>
                        <select asp-for="durum" id="durum" asp-items="Model.Durumlar"
                                class="form-select" style="width:170px;"></select>
                    </div>
                </div>

                <div class="ms-auto">
                    <button class="btn btn-primary px-3 text-nowrap" type="submit">
                        <i class="bi bi-search me-1"></i> Ara
                    </button>
                </div>
            </form>

            <!-- Üst Toplam Kartı -->
            <div class="row g-2 mb-3">
                <div class="col">
                    <div class="border rounded-3 p-2 text-center bg-light">
                        <div class="text-muted small">Toplam Borç</div>
                        <div class="fw-bold text-danger">@Model.ToplamBorc.ToString("C", culture)</div>
                    </div>
                </div>
                <div class="col">
                    <div class="border rounded-3 p-2 text-center bg-light">
                        <div class="text-muted small">Toplam Ödenen</div>
                        <div class="fw-bold text-success">@Model.ToplamOdenen.ToString("C", culture)</div>
                    </div>
                </div>
                <div class="col">
                    <div class="border rounded-3 p-2 text-center bg-light">
                        <div class="text-muted small">Toplam Kalan</div>
                        <div class="fw-bold text-warning">@Model.ToplamKalan.ToString("C", culture)</div>
                    </div>
                </div>
            </div>

            <!-- Liste -->
            @if (list == null || !list.Any())
            {
                <div class="alert alert-warning mb-0">
                    <i class="bi bi-exclamation-triangle-fill"></i> Kayıt bulunamadı.
                </div>
            }
            else
            {
                <div class="table-scroll">
                    <table class="table table-hover table-sm align-middle">
                        <thead class="bg-dark text-white">
                            <tr class="text-center">
                                <th class="text-start">Öğrenci</th>
                                <th>Öğrenci No</th>
                                <th>Sınıf</th>
                                <th class="text-end">Aylık Tarife</th>
                                <th>Aktif Ay</th>
                                <th class="text-end">Borç</th>
                                <th class="text-end">Ödenen</th>
                                <th class="text-end">Kalan</th>
                                <th>Durum</th>
                                <th>İşlem</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var s in list)
                            {
                                string badgeText;
                                string badgeClass;
                                if (!s.TarifeVarMi) { badgeText = "Tarifesiz"; badgeClass = "bg-secondary text-white"; }
                                else if (s.Kalan > 0) { badgeText = "Borçlu"; badgeClass = "bg-danger text-white"; }
                                else { badgeText = "Borçsuz"; badgeClass = "bg-success text-white"; }

                                <tr class="text-center">
                                    <td class="text-start">
                                        <a asp-controller="Yemekhane"
                                           asp-action="Ozet"
                                           asp-route-ogrenciId="@s.OgrenciId"
                                           asp-route-yil="@s.Yil"
                                           class="text-decoration-none">
                                            @s.OgrenciAdSoyad
                                            @if (s.BuAyAktif)
                                            {
                                                <span class="badge bg-info text-dark ms-1" title="Bu ay aktif">●</span>
                                            }
                                        </a>
                                    </td>
                                    <td>@s.OgrenciNo</td>
                                    <td>@s.OgrenciSinif</td>
                                    <td class="text-end">@s.AylikTarife.ToString("C", culture)</td>
                                    <td>@s.AktifAySayisi</td>
                                    <td class="text-end">@s.Borc.ToString("C", culture)</td>
                                    <td class="text-end">@s.Odenen.ToString("C", culture)</td>
                                    <td class="text-end">@s.Kalan.ToString("C", culture)</td>
                                    <td><span class="badge @badgeClass">@badgeText</span></td>
                                    <td>
                                        <a asp-controller="Yemekhane"
                                           asp-action="Ozet"
                                           asp-route-ogrenciId="@s.OgrenciId"
                                           asp-route-yil="@s.Yil"
                                           class="btn btn-outline-primary btn-sm">
                                            <i class="bi bi-info-circle"></i> Detay
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <!-- Sayfalama -->
                <div class="d-flex justify-content-between align-items-center mt-3">
                    <div class="text-muted">
                        Toplam <strong>@list.ToplamSayi</strong> kayıt •
                        Sayfa <strong>@list.SayfaIndeks</strong>/<strong>@list.ToplamSayfa</strong>
                    </div>
                    <div class="btn-group btn-group-gap">
                        <a class="btn btn-outline-secondary @(list.OncekiSayfaVar ? "" : "disabled")"
                           asp-action="Index"
                           asp-route-query="@Model.query"
                           asp-route-yil="@Model.yil"
                           asp-route-birimId="@Model.birimId"
                           asp-route-durum="@((int)Model.durum)"
                           asp-route-includePasif="@(Model.includePasif)"
                           asp-route-page="@(list.SayfaIndeks - 1)"
                           asp-route-pageSize="@list.SayfaBoyutu">
                            ‹ Önceki
                        </a>
                        <a class="btn btn-outline-secondary @(list.SonrakiSayfaVar ? "" : "disabled")"
                           asp-action="Index"
                           asp-route-query="@Model.query"
                           asp-route-yil="@Model.yil"
                           asp-route-birimId="@Model.birimId"
                           asp-route-durum="@((int)Model.durum)"
                           asp-route-includePasif="@(Model.includePasif)"
                           asp-route-page="@(list.SayfaIndeks + 1)"
                           asp-route-pageSize="@list.SayfaBoyutu">
                            Sonraki ›
                        </a>
                    </div>
                </div>
            }
        </div>
    </div>
</div>
