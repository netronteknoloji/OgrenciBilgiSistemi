@model SayfalanmisListeModel<OgrenciBilgiSistemi.Models.VeliProfilModel>

@{
    ViewData["Title"] = "Veli İşlemleri";
    var q = ViewData["CurrentFilter"] as string;
}

<div class="viewport-scroller">
    <div class="fixed-canvas">
        <div class="card border rounded-4 p-4 mt-4">

            <!-- Başlık + aksiyonlar -->
            <div class="d-flex justify-content-between align-items-center mb-4 flex-nowrap no-wrap-scroll">
                <h3 class="text-primary fw-bold mb-0">@ViewData["Title"]</h3>
                <a class="btn btn-success fw-semibold"
                   asp-controller="Veliler"
                   asp-action="Ekle">
                    <i class="bi bi-plus-lg"></i> Veli Ekle
                </a>
            </div>

            <!-- Filtre Formu -->
            <form method="get"
                  asp-controller="Veliler" asp-action="Index"
                  class="d-flex align-items-end gap-3 flex-nowrap no-wrap-scroll w-100 bg-body-tertiary border rounded-3 p-3 mb-3">
                <div>
                    <label for="searchString" class="visually-hidden">Arama</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
                        <input type="text" id="searchString" name="searchString"
                               class="form-control" placeholder="Veli adı veya telefon ara…"
                               value="@q" style="width:280px;" />
                    </div>
                </div>
                <div class="ms-auto">
                    <button class="btn btn-primary px-3 text-nowrap" type="submit">
                        <i class="bi bi-search me-1"></i> Ara
                    </button>
                </div>
            </form>

            <!-- Liste -->
            @if (Model == null || !Model.Any())
            {
                <div class="alert alert-warning mb-0">
                    <i class="bi bi-exclamation-triangle-fill"></i> Kayıt bulunamadı.
                </div>
            }
            else
            {
                <div class="table-scroll">
                    <table class="table table-hover table-sm align-middle">
                        <thead class="bg-dark text-white">
                            <tr class="text-center">
                                <th class="text-start">Kullanıcı Adı</th>
                                <th>Telefon</th>
                                <th>Yakınlık</th>
                                <th>Öğrenci Sayısı</th>
                                <th>Durum</th>
                                <th>İşlem</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var v in Model)
                            {
                                <tr class="text-center">
                                    <td class="text-start fw-semibold text-primary">@(v.Kullanici?.KullaniciAdi ?? "-")</td>
                                    <td>@(v.Kullanici?.Telefon ?? "-")</td>
                                    <td>@(v.VeliYakinlik?.ToString() ?? "-")</td>
                                    <td>
                                        <span class="badge bg-info">@v.OgrenciSayisi</span>
                                    </td>
                                    <td>
                                        <span class="badge @(v.VeliDurum ? "bg-success" : "bg-danger")">
                                            @(v.VeliDurum ? "Aktif" : "Pasif")
                                        </span>
                                    </td>
                                    <td>
                                        <div class="btn-group btn-group-gap" role="group" style="min-width: 240px;">
                                            <a asp-controller="Veliler" asp-action="Detay" asp-route-id="@v.KullaniciId"
                                               class="btn btn-outline-secondary btn-sm">
                                                <i class="bi bi-eye"></i> Detay
                                            </a>
                                            <a asp-controller="Veliler" asp-action="Guncelle" asp-route-id="@v.KullaniciId"
                                               class="btn btn-primary btn-sm">
                                                <i class="bi bi-pencil-square"></i> Güncelle
                                            </a>
                                            <button type="button"
                                                    class="btn btn-danger btn-sm"
                                                    data-bs-toggle="modal"
                                                    data-bs-target="#silModal"
                                                    onclick="document.getElementById('veliId').value='@v.KullaniciId'">
                                                <i class="bi bi-trash"></i> Sil
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @await Html.PartialAsync("_SayfalamaFormPartial", OgrenciBilgiSistemi.ViewModels.SayfalamaVm.Olustur(Model,
                    routeValues: new Dictionary<string, string?> { ["searchString"] = q }))
            }
        </div>
    </div>
</div>

<!-- Silme Modal -->
<div class="modal fade" id="silModal" tabindex="-1" aria-labelledby="silModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="silModalLabel">Veli Sil</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Bu veliyi silmek istediğinize emin misiniz?</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">İptal</button>
                <form id="silForm" method="post" asp-action="Sil">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="veliId" name="id" />
                    <button type="submit" class="btn btn-danger">Evet, Sil!</button>
                </form>
            </div>
        </div>
    </div>
</div>
