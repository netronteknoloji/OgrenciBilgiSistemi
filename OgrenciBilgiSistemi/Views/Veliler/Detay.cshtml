@model OgrenciBilgiSistemi.ViewModels.VeliDetayVm

@{
    ViewData["Title"] = "Veli Detay";
}

<div class="viewport-scroller">
    <div class="fixed-canvas">
        <div class="card rounded-4">
            <!-- Başlık -->
            <div class="card-header rounded-top-4 d-flex flex-row justify-content-between align-items-center gap-2">
                <h5 class="mb-0 text-primary fw-bold">
                    @(Model.Veli.Kullanici?.KullaniciAdi ?? "-") — @(Model.Veli.VeliYakinlik?.ToString() ?? "-")
                </h5>
                <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
                    <i class="bi bi-arrow-left"></i> Listeye Dön
                </a>
            </div>

            <div class="card-body p-4">
                <!-- Veli Bilgileri -->
                <div class="row mb-4">
                    <div class="col-md-6">
                        <dl class="row mb-0">
                            <dt class="col-sm-4">Telefon</dt>
                            <dd class="col-sm-8">@(Model.Veli.Kullanici?.Telefon ?? "-")</dd>

                            <dt class="col-sm-4">E-posta</dt>
                            <dd class="col-sm-8">@(Model.Veli.VeliEmail ?? "-")</dd>

                            <dt class="col-sm-4">Yakınlık</dt>
                            <dd class="col-sm-8">@(Model.Veli.VeliYakinlik?.ToString() ?? "-")</dd>
                        </dl>
                    </div>
                    <div class="col-md-6">
                        <dl class="row mb-0">
                            <dt class="col-sm-4">Meslek</dt>
                            <dd class="col-sm-8">@(Model.Veli.VeliMeslek ?? "-")</dd>

                            <dt class="col-sm-4">İş Yeri</dt>
                            <dd class="col-sm-8">@(Model.Veli.VeliIsYeri ?? "-")</dd>

                            <dt class="col-sm-4">Adres</dt>
                            <dd class="col-sm-8">@(Model.Veli.VeliAdres ?? "-")</dd>
                        </dl>
                    </div>
                </div>

                <hr />

                <!-- Öğrenci Tablosu -->
                <h6 class="fw-bold text-secondary mb-3">Bağlı Öğrenciler</h6>
                <div class="table-scroll">
                    <table class="table table-hover table-sm text-center align-middle">
                        <thead class="bg-dark text-white">
                            <tr>
                                <th>#</th>
                                <th class="text-start">Ad Soyad</th>
                                <th>Öğrenci No</th>
                                <th>Birim</th>
                                <th>Kart No</th>
                            </tr>
                        </thead>
                        <tbody class="bg-white">
                            @if (!Model.Ogrenciler.Any())
                            {
                                <tr>
                                    <td colspan="5" class="p-4">
                                        <div class="alert alert-warning text-center m-0">
                                            <i class="bi bi-exclamation-triangle-fill"></i> Bu veliye bağlı öğrenci bulunmamaktadır.
                                        </div>
                                    </td>
                                </tr>
                            }
                            else
                            {
                                var sira = 1;
                                foreach (var o in Model.Ogrenciler)
                                {
                                    <tr>
                                        <td class="fw-bold text-secondary">@(sira++)</td>
                                        <td class="text-start fw-semibold text-primary">@o.OgrenciAdSoyad</td>
                                        <td>@o.OgrenciNo</td>
                                        <td>@(o.Birim?.BirimAd ?? "-")</td>
                                        <td>@(o.OgrenciKartNo ?? "-")</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Toplam Kayıt -->
        <div class="mt-3 text-end">
            <span class="fw-bold text-muted">
                Toplam <span class="text-primary">@Model.Ogrenciler.Count</span> kayıt listelenmiştir.
            </span>
        </div>
    </div>
</div>
