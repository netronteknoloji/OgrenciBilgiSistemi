@model OgrenciBilgiSistemi.ViewModels.VeliFormVm
@using OgrenciBilgiSistemi.Shared.Enums

@{
    var action = Model.FormAction;
    var submitText = Model.SubmitText;
    var isEkle = action == "Ekle";
}

<div class="viewport-scroller">
    <div class="fixed-canvas">
        <div class="container py-4">
            <div class="row justify-content-center">
                <div class="col-8">
                    <div class="card rounded-3 border">
                        <div class="card-header bg-primary text-white text-center">
                            <h4 class="fw-bold mb-0">
                                @(isEkle ? "Veli Ekle" : "Veli Güncelle")
                            </h4>
                        </div>

                        <div class="card-body p-4">
                            <form method="post" asp-action="@action" autocomplete="off">
                                @Html.AntiForgeryToken()

                                @if (!isEkle)
                                {
                                    <input type="hidden" asp-for="KullaniciId" />
                                }

                                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                                <div class="row g-3">
                                    <!-- Sol Sütun: Kullanıcı Bilgileri -->
                                    <div class="col-6">
                                        <div class="mb-3">
                                            <label asp-for="KullaniciAdi" class="form-label fw-semibold"></label>
                                            <input asp-for="KullaniciAdi" class="form-control" required minlength="3"
                                                   placeholder="Kullanıcı adı giriniz" />
                                            <span asp-validation-for="KullaniciAdi" class="text-danger"></span>
                                        </div>

                                        <div class="mb-3">
                                            <label asp-for="Sifre" class="form-label fw-semibold"></label>
                                            @if (isEkle)
                                            {
                                                <input asp-for="Sifre" type="password" class="form-control"
                                                       required minlength="3" placeholder="Şifre giriniz" />
                                            }
                                            else
                                            {
                                                <input asp-for="Sifre" type="password" class="form-control"
                                                       data-val="false" placeholder="Değiştirmek istemiyorsanız boş bırakın" />
                                                <small class="text-muted">Boş bırakırsanız mevcut şifre korunur.</small>
                                            }
                                            <span asp-validation-for="Sifre" class="text-danger"></span>
                                        </div>

                                        <div class="mb-3">
                                            <label asp-for="Telefon" class="form-label fw-semibold"></label>
                                            <input asp-for="Telefon" class="form-control" placeholder="5XXXXXXXXX" />
                                            <span asp-validation-for="Telefon" class="text-danger"></span>
                                        </div>

                                        <div class="mb-3">
                                            <label asp-for="VeliYakinlik" class="form-label fw-semibold"></label>
                                            <select asp-for="VeliYakinlik" class="form-select"
                                                    asp-items="Html.GetEnumSelectList<YakinlikTipi>()">
                                                <option value="">-- Seçiniz --</option>
                                            </select>
                                            <span asp-validation-for="VeliYakinlik" class="text-danger"></span>
                                        </div>

                                        @if (!isEkle)
                                        {
                                            <div class="mb-3">
                                                <label asp-for="VeliDurum" class="form-label fw-semibold"></label>
                                                <select asp-for="VeliDurum" class="form-select">
                                                    <option value="true">Aktif</option>
                                                    <option value="false">Pasif</option>
                                                </select>
                                                <span asp-validation-for="VeliDurum" class="text-danger"></span>
                                            </div>
                                        }
                                    </div>

                                    <!-- Sağ Sütun: Profil Bilgileri -->
                                    <div class="col-6">
                                        <div class="mb-3">
                                            <label asp-for="VeliAdres" class="form-label fw-semibold"></label>
                                            <input asp-for="VeliAdres" class="form-control" placeholder="Adres" />
                                            <span asp-validation-for="VeliAdres" class="text-danger"></span>
                                        </div>

                                        <div class="mb-3">
                                            <label asp-for="VeliMeslek" class="form-label fw-semibold"></label>
                                            <input asp-for="VeliMeslek" class="form-control" placeholder="Meslek" />
                                            <span asp-validation-for="VeliMeslek" class="text-danger"></span>
                                        </div>

                                        <div class="mb-3">
                                            <label asp-for="VeliIsYeri" class="form-label fw-semibold"></label>
                                            <input asp-for="VeliIsYeri" class="form-control" placeholder="İş yeri" />
                                            <span asp-validation-for="VeliIsYeri" class="text-danger"></span>
                                        </div>

                                        <div class="mb-3">
                                            <label asp-for="VeliEmail" class="form-label fw-semibold"></label>
                                            <input asp-for="VeliEmail" type="email" class="form-control" placeholder="ornek@email.com" />
                                            <span asp-validation-for="VeliEmail" class="text-danger"></span>
                                        </div>
                                    </div>
                                </div>

                                <!-- Butonlar -->
                                <div class="d-flex justify-content-between gap-2 mt-3">
                                    <a asp-action="Index" class="btn btn-outline-secondary">
                                        <i class="bi bi-arrow-left"></i> Geri Dön
                                    </a>
                                    <button type="submit" class="btn btn-primary fw-bold">
                                        <i class="bi bi-save"></i> @submitText
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
