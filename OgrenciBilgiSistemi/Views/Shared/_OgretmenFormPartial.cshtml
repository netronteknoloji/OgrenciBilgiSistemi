@model OgrenciBilgiSistemi.ViewModels.OgretmenFormVm

@{
    var action = Model.FormAction;
    var submitText = Model.SubmitText;
    var isEkle = action == "Ekle";
}

<div class="viewport-scroller">
    <div class="fixed-canvas">
        <div class="container py-4">
            <div class="row justify-content-center">
                <div class="col-5">
                    <div class="card rounded-3 border">
                        <div class="card-header bg-primary text-white text-center">
                            <h4 class="fw-bold mb-0">
                                @(isEkle ? "Öğretmen Ekle" : "Öğretmen Güncelle")
                            </h4>
                        </div>

                        <div class="card-body p-4">
                            <form method="post" asp-action="@action" enctype="multipart/form-data" autocomplete="off">
                                @Html.AntiForgeryToken()

                                @if (!isEkle)
                                {
                                    <input type="hidden" asp-for="KullaniciId" />
                                }

                                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                                <!-- Kullanıcı Adı -->
                                <div class="mb-3">
                                    <label asp-for="KullaniciAdi" class="form-label fw-semibold"></label>
                                    <input asp-for="KullaniciAdi" class="form-control" required minlength="3"
                                           placeholder="Kullanıcı adı giriniz" />
                                    <span asp-validation-for="KullaniciAdi" class="text-danger"></span>
                                </div>

                                <!-- Şifre -->
                                <div class="mb-3">
                                    <label asp-for="Sifre" class="form-label fw-semibold"></label>
                                    @if (isEkle)
                                    {
                                        <input asp-for="Sifre" type="password" class="form-control"
                                               required minlength="3" placeholder="Şifre giriniz" />
                                    }
                                    else
                                    {
                                        <input asp-for="Sifre" type="password" class="form-control"
                                               data-val="false" placeholder="Değiştirmek istemiyorsanız boş bırakın" />
                                        <small class="text-muted">Boş bırakırsanız mevcut şifre korunur.</small>
                                    }
                                    <span asp-validation-for="Sifre" class="text-danger"></span>
                                </div>

                                <!-- Telefon -->
                                <div class="mb-3">
                                    <label asp-for="Telefon" class="form-label fw-semibold"></label>
                                    <input asp-for="Telefon" class="form-control" placeholder="5XXXXXXXXX" />
                                    <span asp-validation-for="Telefon" class="text-danger"></span>
                                </div>

                                <hr class="my-3" />

                                <!-- E-posta -->
                                <div class="mb-3">
                                    <label asp-for="Email" class="form-label fw-semibold"></label>
                                    <input asp-for="Email" class="form-control" placeholder="ornek@okul.edu.tr" />
                                    <span asp-validation-for="Email" class="text-danger"></span>
                                </div>

                                <!-- Birim -->
                                <div class="mb-3">
                                    <label asp-for="BirimId" class="form-label fw-semibold"></label>
                                    <select asp-for="BirimId" class="form-select" asp-items="Model.Birimler">
                                        <option value="">-- Birim Seçiniz --</option>
                                    </select>
                                    <span asp-validation-for="BirimId" class="text-danger"></span>
                                </div>

                                <!-- Fotoğraf -->
                                <div class="mb-3">
                                    <label asp-for="GorselFile" class="form-label fw-semibold"></label>
                                    @if (!string.IsNullOrEmpty(Model?.GorselPath))
                                    {
                                        <div class="mb-2">
                                            <img src="@Model.GorselPath" alt="Mevcut fotoğraf"
                                                 class="rounded" style="max-height:120px;" />
                                        </div>
                                    }
                                    <input asp-for="GorselFile" type="file" class="form-control" accept="image/*" />
                                    <span asp-validation-for="GorselFile" class="text-danger"></span>
                                </div>

                                @if (!isEkle)
                                {
                                    <!-- Durum -->
                                    <div class="mb-3">
                                        <label asp-for="OgretmenDurum" class="form-label fw-semibold"></label>
                                        <select asp-for="OgretmenDurum" class="form-select">
                                            <option value="true">Aktif</option>
                                            <option value="false">Pasif</option>
                                        </select>
                                        <span asp-validation-for="OgretmenDurum" class="text-danger"></span>
                                    </div>
                                }

                                <!-- Butonlar -->
                                <div class="d-flex justify-content-between gap-2">
                                    <a asp-action="Index" class="btn btn-outline-secondary">
                                        <i class="bi bi-arrow-left"></i> Geri Dön
                                    </a>
                                    <button type="submit" class="btn btn-primary fw-bold">
                                        <i class="bi bi-save"></i> @submitText
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
